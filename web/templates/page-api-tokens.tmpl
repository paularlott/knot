{{ template "layout-base.tmpl" . }}

{{ define "pageTitle" }}API Tokens{{ end }}

{{ define "mainContent" }}
<main class="relative w-full h-full overflow-y-auto lg:ml-64 pb-8" x-data="apiTokensComponent()" x-init="getTokens">
  <div class="grid grid-cols-1 px-4 pt-6 xl:grid-cols-4 gap-2 xl:gap-4">

    <div class="col-span-full">
      <h1 class="text-xl font-semibold text-gray-900 sm:text-2xl dark:text-white">API Tokens</h1>
    </div>

    <form class="app-toolbar col-span-full">
      <div>
        <label for="search" class="sr-only">Search</label>
        <div class="relative mt-1 sm:w-48 lg:w-64 xl:w-96 flex items-center">
          <input type="search" name="search" id="search" class="form-field grow pr-24 app-page-search" placeholder="Search" x-model="searchTerm" x-on:input="searchChanged" x-ref="searchInput">
          <button type="button" x-show="searchTerm" x-cloak @click="searchTerm=''; searchChanged(); $refs.searchInput.focus()" aria-label="Clear search" class="app-search-clear"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg></button><div class="app-search-shortcut">⌘ K</div>
        </div>
      </div>
      <div>
        <button @click.prevent="createToken" class="btn-primary flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4 mr-2" aria-hidden="true" >
            <path fill-rule="evenodd" d="M12 3.75a.75.75 0 0 1 .75.75v6.75h6.75a.75.75 0 0 1 0 1.5h-6.75v6.75a.75.75 0 0 1-1.5 0v-6.75H4.5a.75.75 0 0 1 0-1.5h6.75V4.5a.75.75 0 0 1 .75-.75Z" clip-rule="evenodd" />
          </svg>
          Token
        </button>
      </div>
    </form>

    <div class="p-4 mb-4 bg-white border border-gray-200 rounded-lg shadow-xs col-span-full dark:border-gray-700 sm:p-6 dark:bg-gray-800">

      {{ template "loading" . }}
      <div x-show="!loading" x-cloak class="relative overflow-x-auto sm:rounded-lg">
        <table aria-label="API tokens" class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
          <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400 border-b dark:border-gray-700">
            <tr>
              <th scope="col" class="px-4 py-3">Details</th>
              <th scope="col" class="px-4 py-3 hidden sm:table-cell">Name</th>
              <th scope="col" class="px-4 py-3 hidden md:table-cell">Scopes</th>
              <th scope="col" class="px-4 py-3">&nbsp;</th>
            </tr>
          </thead>
          <tbody>
          <template x-for="t in tokens" :key="t.token_id">
            <tr x-show="!t.searchHide" class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600/10">
              <td class="px-4 py-3">
                <div class="flex flex-nowrap text-xs p-2 bg-gray-100 dark:bg-gray-700 rounded-lg cursor-pointer w-full" @click.debounce.750="copyToClipboard(t.token_id)">
                  <input type="text" readonly aria-label="Token ID" class="shrink grow w-full p-0 text-xs bg-gray-100 dark:bg-gray-700 rounded-lg cursor-pointer outline-0 border-0 focus:border-0 focus:ring-0" x-model="t.token_id" @click.debounce.750="copyToClipboard(t.token_id)" />
                  <div class="shrink-0 grow-0">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5 ml-2 flex-shrink-0 self-end" aria-hidden="true" >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75" />
                    </svg>
                  </div>
                </div>
                <div class="sm:hidden">
                  <div class="mt-1 text-sm font-medium text-gray-900 dark:text-white" x-text="t.name"></div>
                </div>
              </td>
              <td x-text="t.name" class="px-4 py-3 align-middle hidden sm:table-cell"></td>
              <td class="px-4 py-3 align-middle hidden md:table-cell">
                <span x-show="!t.scopes || !t.scopes.length" class="app-badge-neutral">Full Access</span>
                <template x-if="t.scopes && t.scopes.length">
                  <div class="flex flex-wrap gap-1">
                    <template x-for="(scope, index) in scopeLabelList(t)" :key="index">
                      <span class="app-badge-info" x-text="scope"></span>
                    </template>
                  </div>
                </template>
              </td>
              <td class="px-4 py-3">
                <div class="flex items-center justify-end gap-1">
                  <button @click="openEdit(t)" class="row-action-button" type="button" :aria-label="'Edit API token ' + t.name" title="Edit">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                    </svg>
                    <span class="sr-only">Edit</span>
                  </button>
                  <button @click="deleteConfirm.show = true; deleteConfirm.token = t" class="row-action-button row-action-danger" type="button" :aria-label="'Delete API token ' + t.name" title="Delete">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true" >
                      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg>
                    <span class="sr-only">Delete</span>
                  </button>
                </div>
              </td>
            </tr>
          </template>
          </tbody>
        </table>
      </div>

      <!-- Modal delete -->
      <div x-cloak x-show="deleteConfirm.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="deleteConfirm.show" @keydown.esc.window="deleteConfirm.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="deleteConfirmTitle">
        <div x-show="deleteConfirm.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel">
          <div class="ui-modal-header">
            <div class="ui-modal-icon-danger">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true" >
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
              </svg>
            </div>
            <h3 id="deleteConfirmTitle" class="ui-modal-title">Confirm Delete</h3>
            <button @click="deleteConfirm.show = false;" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="ui-modal-body text-center">
            <p>Are you sure you want to delete the API token <strong x-text="deleteConfirm.token.name"></strong>?</p>
            <p>Deleting the token may prevent access.</p>
          </div>
          <div class="ui-modal-footer">
              <button @click="deleteConfirm.show = false" type="button" class="ui-button-secondary">Keep Token</button>
              <button @click="deleteToken(deleteConfirm.token.token_id); deleteConfirm.show = false" type="button" class="ui-button-danger">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 mr-2" aria-hidden="true" >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                </svg> Delete Token
              </button>
          </div>
        </div>
      </div>

    </div>

    <!-- Modal create token -->
    <div x-cloak x-show="tokenFormModal.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="tokenFormModal.show" @keydown.esc.window="tokenFormModal.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="tokenModalTitle">
      <div x-show="tokenFormModal.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel-wide max-h-[90vh]">
        <div class="ui-modal-header">
          <div class="ui-modal-icon-info">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z" />
            </svg>
          </div>
          <h3 id="tokenModalTitle" class="ui-modal-title">Create API Token</h3>
          <button @click="tokenFormModal.show = false" aria-label="close modal" class="ui-modal-close">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <template x-if="tokenFormModal.show">
          <form class="contents" @submit.prevent="submitTokenForm">
            <div class="flex-1 overflow-y-auto p-5 space-y-6">
            <div>
              <label for="name" class="form-label">Token Name</label>
              <input type="text" id="name" name="name" class="form-field" x-on:keyup.debounce.500ms="checkName()" :class="{'form-field-error': !nameValid}" placeholder="Token name" x-model="createForm.name">
              <div x-show="!nameValid" class="error-message" x-cloak>The token name is required and must be shorter than 255 characters.</div>
            </div>

            <!-- Scopes -->
            <fieldset class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
              <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Access Level</legend>
              <div class="space-y-4 mt-2">
                <div class="description">Choose what this token can access. Full Access removes all restrictions; scoped tokens are limited to the selected endpoint groups.</div>
                <label class="flex items-center cursor-pointer">
                  <input type="checkbox" class="sr-only peer" x-model="createForm.fullAccess">
                  <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                  <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Full Access</span>
                  <span class="ms-2 text-xs text-gray-500 dark:text-gray-400">— token can reach any endpoint the user has permission for</span>
                </label>
                <div x-show="!createForm.fullAccess" class="pl-6 space-y-4">
                  <template x-for="scope in availableScopes" :key="scope.value">
                    <label class="flex items-center cursor-pointer">
                      <input type="checkbox" class="sr-only peer" x-model="createForm.scopes[scope.value]">
                      <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                      <div class="ms-3">
                        <span class="text-sm font-medium text-gray-900 dark:text-gray-300" x-text="scope.label"></span>
                        <span class="block text-xs text-gray-500 dark:text-gray-400" x-text="scope.description"></span>
                      </div>
                    </label>
                  </template>
                </div>
              </div>
            </fieldset>
            </div>

            <div class="ui-modal-footer">
              <button type="button" @click="tokenFormModal.show = false" class="ui-button-secondary sm:mr-auto">Cancel</button>
              <button type="submit" class="btn-primary" :disabled="loading">Create Token</button>
            </div>
          </form>
        </template>
      </div>
    </div>

    <!-- Modal edit token -->
    <div x-cloak x-show="editModal.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="editModal.show" @keydown.esc.window="editModal.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="editModalTitle">
      <div x-show="editModal.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel-wide max-h-[90vh]">
        <div class="ui-modal-header">
          <div class="ui-modal-icon-info">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" />
            </svg>
          </div>
          <h3 id="editModalTitle" class="ui-modal-title">Edit API Token</h3>
          <button @click="editModal.show = false" aria-label="close modal" class="ui-modal-close">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
        <template x-if="editModal.show">
          <form class="contents" @submit.prevent="submitEditForm">
            <div class="flex-1 overflow-y-auto p-5 space-y-6">
            <div>
              <label for="edit-name" class="form-label">Token Name</label>
              <input type="text" id="edit-name" name="name" class="form-field" x-on:keyup.debounce.500ms="checkEditName()" :class="{'form-field-error': !editNameValid}" placeholder="Token name" x-model="editForm.name">
              <div x-show="!editNameValid" class="error-message" x-cloak>The token name is required and must be shorter than 255 characters.</div>
            </div>

            <!-- Scopes -->
            <fieldset class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
              <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Access Level</legend>
              <div class="space-y-4 mt-2">
                <div class="description">Choose what this token can access. Full Access removes all restrictions; scoped tokens are limited to the selected endpoint groups.</div>
                <label class="flex items-center cursor-pointer">
                  <input type="checkbox" class="sr-only peer" x-model="editForm.fullAccess">
                  <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                  <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Full Access</span>
                  <span class="ms-2 text-xs text-gray-500 dark:text-gray-400">— token can reach any endpoint the user has permission for</span>
                </label>
                <div x-show="!editForm.fullAccess" class="pl-6 space-y-4">
                  <template x-for="scope in availableScopes" :key="scope.value">
                    <label class="flex items-center cursor-pointer">
                      <input type="checkbox" class="sr-only peer" x-model="editForm.scopes[scope.value]">
                      <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                      <div class="ms-3">
                        <span class="text-sm font-medium text-gray-900 dark:text-gray-300" x-text="scope.label"></span>
                        <span class="block text-xs text-gray-500 dark:text-gray-400" x-text="scope.description"></span>
                      </div>
                    </label>
                  </template>
                </div>
              </div>
            </fieldset>
            </div>

            <div class="ui-modal-footer">
              <button type="button" @click="editModal.show = false" class="ui-button-secondary sm:mr-auto">Cancel</button>
              <button type="submit" class="btn-primary" :disabled="loading">Save Changes</button>
            </div>
          </form>
        </template>
      </div>
    </div>

  </div>
</main>
{{ end }}
