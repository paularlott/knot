                        <svg x-show="stackBusy[group.name] !== true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4" aria-hidden="true"><path fill-rule="evenodd" d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z" clip-rule="evenodd"/></svg>
                        <svg x-show="stackBusy[group.name] === true" x-cloak class="size-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        Stop
                      </button>
                      <button x-show="group.spaces.some(s => s.is_local) && group.spaces.every(s => s.is_deployed)" @click.stop="restartStack(group.name)" :disabled="stackBusy[group.name] === true" type="button" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-xs font-medium text-blue-700 transition-colors hover:bg-slate-100 hover:text-blue-800 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white disabled:cursor-not-allowed disabled:opacity-50 dark:border-slate-700 dark:bg-slate-800/45 dark:text-blue-400 dark:hover:bg-slate-700/70 dark:hover:text-blue-300 dark:focus-visible:ring-offset-slate-900">
                        <svg x-show="stackBusy[group.name] !== true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4" aria-hidden="true"><path fill-rule="evenodd" d="M4.755 10.059a7.5 7.5 0 0 1 12.548-3.364l1.903 1.903h-3.183a.75.75 0 1 0 0 1.5h4.992a.75.75 0 0 0 .75-.75V4.356a.75.75 0 0 0-1.5 0v3.18l-1.9-1.9A9 9 0 0 0 3.306 9.67a.75.75 0 1 0 1.45.388Zm15.408 3.352a.75.75 0 0 0-.919.53 7.5 7.5 0 0 1-12.548 3.364l-1.902-1.903h3.183a.75.75 0 0 0 0-1.5H2.984a.75.75 0 0 0-.75.75v4.992a.75.75 0 0 0 1.5 0v-3.18l1.9 1.9a9 9 0 0 0 15.059-4.035.75.75 0 0 0-.53-.918Z" clip-rule="evenodd"/></svg>
                        <svg x-show="stackBusy[group.name] === true" x-cloak class="size-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        Restart
                      </button>
                      <button x-show="group.spaces.some(s => s.is_local) && group.spaces.every(s => !s.is_deployed && !s.is_pending && !s.is_deleting)" @click.stop="deleteStackConfirm.show = true; deleteStackConfirm.stack = group.name; deleteStackConfirm.count = group.count" :disabled="stackBusy[group.name] === true" type="button" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-xs font-medium text-red-700 transition-colors hover:bg-slate-100 hover:text-red-800 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:ring-offset-white disabled:cursor-not-allowed disabled:opacity-50 dark:border-slate-700 dark:bg-slate-800/45 dark:text-red-400 dark:hover:bg-slate-700/70 dark:hover:text-red-300 dark:focus-visible:ring-offset-slate-900">
                        <svg x-show="stackBusy[group.name] !== true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4" aria-hidden="true"><path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 0 1 3.878.512.75.75 0 1 1-.256 1.478l-.209-.035-1.005 13.07a3 3 0 0 1-2.991 2.77H8.084a3 3 0 0 1-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 0 1-.256-1.478A48.567 48.567 0 0 1 7.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 0 1 3.369 0c1.603.051 2.815 1.387 2.815 2.951Zm-6.136-1.452a51.196 51.196 0 0 0 3.273 0C14.39 3.052 15 3.683 15 4.478v.113a49.488 49.488 0 0 0-6 0v-.113c0-.795.61-1.426 1.364-1.452Zm-.355 5.945a.75.75 0 1 0-1.5.058l.347 9a.75.75 0 1 0 1.499-.058l-.346-9Zm5.48.058a.75.75 0 1 0-1.498-.058l-.347 9a.75.75 0 0 0 1.5.058l.345-9Z" clip-rule="evenodd"/></svg>
                        <svg x-show="stackBusy[group.name] === true" x-cloak class="size-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        Delete
                      </button>
                    </div>
                  </div>
                </td>
              </tr>
              <!-- Space rows in this stack -->
              <template x-for="space in group.spaces" :key="space.space_id">
                <tr x-show="!collapsedStacks[group.name]" x-data="{ s: space }" class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600/10">
                  {{ template "space-row-cells" . }}
                </tr>
              </template>
            </tbody>
          </template>

          <!-- Pool groups - collapsed by default, real space rows -->
          <template x-for="pg in poolSpaceGroups()" :key="'pool-' + pg.pool.pool_id">
            <tbody>
              <!-- Pool header row -->
              <tr class="bg-gray-50 dark:bg-gray-700/50 border-b dark:border-gray-700">
                <td colspan="6" class="px-4 py-2">
                  <div class="flex items-center gap-2">
                    <div class="flex items-center gap-2 cursor-pointer select-none flex-1" @click="togglePool(pg.pool.pool_id)">
                      <svg :class="{'rotate-90': collapsedPools[pg.pool.pool_id] === false}" class="size-3 text-gray-500 dark:text-gray-400 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
                      <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Pool:</span>
                      <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" x-text="pg.pool.name"></span>
                      <span class="text-xs text-gray-500 dark:text-gray-400" x-text="'(' + pg.spaces.filter(s => s.is_deployed && !s.is_pending).length + ' / ' + pg.pool.desired_count + ' space' + (pg.pool.desired_count !== 1 ? 's' : '') + ')'"></span>
                      <span class="inline-flex items-center rounded px-1.5 py-0.5 text-xs font-medium" :class="pg.pool.active ? 'bg-green-100 text-green-800 dark:bg-green-900/40 dark:text-green-300' : 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300'" x-text="pg.pool.active ? 'Active' : 'Stopped'"></span>
                      <template x-if="pg.pool.utilization">
                        <span class="text-xs text-gray-500 dark:text-gray-400" x-text="Number(pg.pool.utilization?.combined_rps || 0).toFixed(1) + ' rps · ' + Number(pg.pool.utilization?.avg_cpu_percent || 0).toFixed(0) + '% cpu · ' + Number(pg.pool.utilization?.avg_memory_percent || 0).toFixed(0) + '% mem'"></span>
                      </template>
                    </div>
                    <div class="flex items-center gap-1 ml-auto">
                      <button x-show="canUsePools && !pg.pool.active" @click.stop="poolAction(pg.pool, 'start')" :disabled="poolBusy[pg.pool.pool_id] === true" type="button" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-xs font-medium text-green-700 transition-colors hover:bg-slate-100 disabled:cursor-not-allowed disabled:opacity-50 dark:border-slate-700 dark:bg-slate-800/45 dark:text-green-400 dark:hover:bg-slate-700/70">
                        <svg x-show="poolBusy[pg.pool.pool_id] !== true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4" aria-hidden="true"><path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd"/></svg>
                        <svg x-show="poolBusy[pg.pool.pool_id] === true" x-cloak class="size-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        Start
                      </button>
                      <button x-show="canUsePools && pg.pool.active" @click.stop="poolAction(pg.pool, 'stop')" :disabled="poolBusy[pg.pool.pool_id] === true" type="button" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-xs font-medium text-red-700 transition-colors hover:bg-slate-100 disabled:cursor-not-allowed disabled:opacity-50 dark:border-slate-700 dark:bg-slate-800/45 dark:text-red-400 dark:hover:bg-slate-700/70">
                        <svg x-show="poolBusy[pg.pool.pool_id] !== true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4" aria-hidden="true"><path fill-rule="evenodd" d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z" clip-rule="evenodd"/></svg>
                        <svg x-show="poolBusy[pg.pool.pool_id] === true" x-cloak class="size-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        Stop
                      </button>
                      <button x-show="canUsePools && pg.pool.pool_id" @click.stop="openEditPool(pg.pool)" :disabled="poolBusy[pg.pool.pool_id] === true" type="button" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-xs font-medium text-blue-700 transition-colors hover:bg-slate-100 disabled:cursor-not-allowed disabled:opacity-50 dark:border-slate-700 dark:bg-slate-800/45 dark:text-blue-400 dark:hover:bg-slate-700/70">
                        <svg x-show="poolBusy[pg.pool.pool_id] !== true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Z" /></svg>
                        <svg x-show="poolBusy[pg.pool.pool_id] === true" x-cloak class="size-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        Edit
                      </button>
                      <button x-show="canUsePools && !pg.pool.active && pg.pool.pool_id" @click.stop="deletePoolConfirm.show = true; deletePoolConfirm.pool = pg.pool" :disabled="poolBusy[pg.pool.pool_id] === true" type="button" class="inline-flex items-center gap-1.5 rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-xs font-medium text-red-700 transition-colors hover:bg-slate-100 disabled:cursor-not-allowed disabled:opacity-50 dark:border-slate-700 dark:bg-slate-800/45 dark:text-red-400 dark:hover:bg-slate-700/70">
                        <svg x-show="poolBusy[pg.pool.pool_id] !== true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4" aria-hidden="true"><path fill-rule="evenodd" d="M16.5 4.478v.227a48.816 48.816 0 0 1 3.878.512.75.75 0 1 1-.256 1.478l-.209-.035-1.005 13.07a3 3 0 0 1-2.991 2.77H8.084a3 3 0 0 1-2.991-2.77L4.087 6.66l-.209.035a.75.75 0 0 1-.256-1.478A48.567 48.567 0 0 1 7.5 4.705v-.227c0-1.564 1.213-2.9 2.816-2.951a52.662 52.662 0 0 1 3.369 0c1.603.051 2.815 1.387 2.815 2.951Z" clip-rule="evenodd"/></svg>
                        <svg x-show="poolBusy[pg.pool.pool_id] === true" x-cloak class="size-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        Delete
                      </button>
                    </div>
                  </div>
                </td>
              </tr>
              <!-- Pool member rows - real space rows, no management actions -->
              <template x-for="space in pg.spaces" :key="space.space_id">
                <tr x-show="collapsedPools[pg.pool.pool_id] === false" x-data="{ s: space }" class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600/10">
                  {{ template "space-row-cells" . }}
                </tr>
              </template>
            </tbody>
          </template>
        </table>
      </div>

      <!-- Modal choose user -->
      <div x-cloak x-show="chooseUser.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="chooseUser.show" @keydown.esc.window="chooseUser.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="chooseUserTitle">
        <!-- Modal Dialog -->
        <div x-show="chooseUser.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel overflow-visible rounded-2xl">
          <!-- Dialog Header -->
          <div class="ui-modal-header rounded-t-2xl">
            <div x-cloak x-show="!chooseUser.isShare" class="ui-modal-icon-danger">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true" >
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"></path>
              </svg>
            </div>
            <div x-cloak x-show="chooseUser.isShare" class="ui-modal-icon-info">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true" >
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z" />
              </svg>
            </div>
            <h3 id="chooseUserTitle" class="ui-modal-title" x-text="chooseUser.isShare ? 'Share Space With' : 'Transfer Space To'"></h3>
            <button @click="chooseUser.show = false;" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <!-- Dialog Body -->
          <div class="ui-modal-body bg-white dark:bg-gray-900">
            <p x-cloak x-show="!chooseUser.isShare">Select the user to transfer the space to.</p>
            <p x-cloak x-show="chooseUser.isShare">Select the user to share the space with.</p>
            <div x-data="autocompleterUser()" x-init="setDataSource('shareUsers')" data-parent-var-group="chooseUser" data-parent-variable="toUserId" data-parent-variable-username="toUserUsername" @refresh-autocompleter.window="refresh()" class="relative mt-2">
              <input x-model="search" class="form-field" type="search" placeholder="Search for user..." aria-label="Search users" role="combobox" :aria-expanded="showList && filteredOptions.length > 0" :aria-activedescendant="activeDescendant" :aria-controls="_listboxId" @focus="handleFocus()" @blur.debounce.200ms="showList = false" @keydown="handleKeydown($event)" x-ref="searchInput" x-init="$nextTick(() => $refs.searchInput.focus())" autofocus>
              <div x-show="showList && filteredOptions.length" x-cloak class="w-full max-h-40 overflow-auto absolute z-50 my-1 text-base p-2 list-none bg-white divide-y divide-gray-100 rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 block whitespace-nowrap">
                <ul class="list-none" role="listbox" :id="_listboxId">
                  <template x-for="(option, index) in filteredOptions" :key="index">
                    <li @click="selectOption(option)" :id="`${_listboxId}-opt-${index}`" role="option" :aria-selected="selectedIndex === index" :class="{'bg-blue-100 dark:bg-blue-900': selectedIndex === index}" class="my-1 cursor-pointer nav-item text-sm">
                      {{ if .useGravatar }}
                      <img :src="`https://www.gravatar.com/avatar/${MD5(option.email)}?s=64&d=mp`" alt="User Avatar" class="size-5 rounded-full mr-2">
                      {{ end }}
                      <div x-text="option.username"></div>
                    </li>
                  </template>
                </ul>
              </div>
            </div>
            <div x-show="chooseUser.invalidUser" class="error-message" x-cloak>Select a valid user.</div>

          </div>
          <!-- Dialog Footer -->
          <div class="ui-modal-footer rounded-b-2xl">
              <button @click="chooseUser.show = false" type="button" class="ui-button-secondary">Cancel</button>
              <button x-show="!chooseUser.isShare && chooseUser.toUserId != ''" x-cloak @click="transferSpaceTo" type="button" class="ui-button-danger">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 mr-2" aria-hidden="true" >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"></path>
                </svg> <span x-text="'Transfer Space to ' + chooseUser.toUserUsername"></span>
              </button>
              <button x-show="chooseUser.isShare && chooseUser.toUserId != ''" x-cloak @click="transferSpaceTo" type="button" class="ui-button-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 mr-2" aria-hidden="true" >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z" />
                </svg> <span x-text="'Share Space with ' + chooseUser.toUserUsername"></span>
              </button>
          </div>
        </div>
      </div>

      <!-- Modal -->
      <div x-cloak x-show="deleteConfirm.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="deleteConfirm.show" @keydown.esc.window="deleteConfirm.show = false; deleteConfirm.space.deleting = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="deleteConfirmTitle">
        <!-- Modal Dialog -->
        <div x-show="deleteConfirm.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel">
          <!-- Dialog Header -->
          <div class="ui-modal-header">
            <div class="ui-modal-icon-danger">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true" >
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
              </svg>
