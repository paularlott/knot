            <div class="ui-modal-icon-info">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h12A2.25 2.25 0 0 0 20.25 14.25V3M3.75 3h16.5M3.75 3v-.75A2.25 2.25 0 0 1 6 0h12a2.25 2.25 0 0 1 2.25 2.25V3M6.75 20.25h10.5" />
              </svg>
            </div>
            <h3 id="spaceUsageTitle" class="ui-modal-title" x-text="spaceUsageModal.spaceName"></h3>
            <button @click="closeSpaceUsage()" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="ui-modal-body-scroll max-h-[75vh]">
            <template x-if="spaceUsageModal.show">
              <div x-data="spaceUsageComponent(spaceUsageModal.spaceId, spaceUsageModal.spaceName)" x-init="init()" x-effect="spaceUsageModal.show || destroy()">
                <p class="text-sm text-gray-500 dark:text-gray-400">CPU, memory, and disk usage over the last 7 days.</p>

                <div x-show="showCurrentCards()" x-cloak class="mt-4 grid grid-cols-1 lg:grid-cols-3 gap-4">
                  <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs dark:border-gray-700 dark:bg-gray-800">
                    <div class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">CPU</div>
                    <div class="mt-2 text-2xl font-semibold text-gray-900 dark:text-white" x-text="formatPercent(current.resource_usage?.cpu_percent || 0)"></div>
                    <div class="mt-3 h-2 rounded-full bg-gray-200 dark:bg-gray-700 overflow-hidden">
                      <div class="h-full rounded-full bg-blue-500 transition-all duration-300" :style="`width: ${usagePercent(current.resource_usage?.cpu_percent || 0, 100)}%`"></div>
                    </div>
                  </div>

                  <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs dark:border-gray-700 dark:bg-gray-800">
                    <div class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Memory</div>
                    <div class="mt-2 text-2xl font-semibold text-gray-900 dark:text-white" x-text="formatUsage(current.resource_usage?.memory_used_bytes || 0, current.resource_usage?.memory_limit_bytes || 0)"></div>
                    <div class="mt-3 h-2 rounded-full bg-gray-200 dark:bg-gray-700 overflow-hidden">
                      <div class="h-full rounded-full bg-emerald-500 transition-all duration-300" :style="`width: ${usagePercent(current.resource_usage?.memory_used_bytes || 0, current.resource_usage?.memory_limit_bytes || 0)}%`"></div>
                    </div>
                  </div>

                  <div class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs dark:border-gray-700 dark:bg-gray-800">
                    <div class="text-xs font-medium uppercase tracking-wide text-gray-500 dark:text-gray-400">Disk</div>
                    <div class="mt-2 text-2xl font-semibold text-gray-900 dark:text-white" x-text="formatUsage(current.resource_usage?.disk_used_bytes || 0, current.resource_usage?.disk_limit_bytes || 0)"></div>
                    <div class="mt-3 h-2 rounded-full bg-gray-200 dark:bg-gray-700 overflow-hidden">
                      <div class="h-full rounded-full bg-amber-500 transition-all duration-300" :style="`width: ${usagePercent(current.resource_usage?.disk_used_bytes || 0, current.resource_usage?.disk_limit_bytes || 0)}%`"></div>
                    </div>
                  </div>
                </div>

                <div :class="showCurrentCards() ? 'mt-4' : 'mt-0'" class="p-4 bg-white border border-gray-200 rounded-lg shadow-xs dark:border-gray-700 dark:bg-gray-800">
                  <div class="flex items-center justify-between gap-4">
                    <div>
                      <h4 class="text-lg font-semibold text-gray-900 dark:text-white">History</h4>
                      <p class="text-sm text-gray-500 dark:text-gray-400" x-text="selectedRange === '1h' ? 'Per-minute history for the last hour.' : 'Daily rollup for the last 7 days.'"></p>
                    </div>
                    <div class="inline-flex rounded-lg border border-gray-200 dark:border-gray-700 overflow-hidden">
                      <button type="button" @click="setRange('1h')" :class="selectedRange === '1h' ? 'bg-blue-600 text-white' : 'bg-white text-gray-600 dark:bg-gray-800 dark:text-gray-300'" class="px-3 py-1.5 text-xs font-medium">Last Hour</button>
                      <button type="button" @click="setRange('7d')" :class="selectedRange === '7d' ? 'bg-blue-600 text-white' : 'bg-white text-gray-600 dark:bg-gray-800 dark:text-gray-300'" class="px-3 py-1.5 text-xs font-medium border-l border-gray-200 dark:border-gray-700">Last 7 Days</button>
                    </div>
                  </div>
                  <div class="mt-4 h-[28rem]">
                    <canvas x-ref="historyChart"></canvas>
                  </div>
                </div>
              </div>
            </template>
          </div>
        </div>
      </div>

      <!-- Modal: Space Form -->
      <div x-cloak x-show="spaceFormModal.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="spaceFormModal.show" @keydown.esc.window="spaceFormModal.show = false" @close-space-form.window="spaceFormModal.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="spaceFormTitle">
        <div x-show="spaceFormModal.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel-wide">
          <div class="ui-modal-header">
            <div class="ui-modal-icon-info">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15a4.5 4.5 0 0 0 4.5 4.5H18a3.75 3.75 0 0 0 1.332-7.257 3 3 0 0 0-3.758-3.848 5.25 5.25 0 0 0-10.233 2.33A4.502 4.502 0 0 0 2.25 15Z" />
              </svg>
            </div>
            <h3 id="spaceFormTitle" class="ui-modal-title" x-text="spaceFormModal.isEdit ? 'Edit Space' : 'Create Space'"></h3>
            <button @click="spaceFormModal.show = false" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5" aria-hidden="true" >
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="ui-modal-body-scroll max-h-[70vh] relative">
            <template x-if="spaceFormModal.show">
              {{ template "space-form-content" . }}
            </template>
          </div>
        </div>
      </div>

      <!-- Modal: Template Selector -->
      <div x-cloak x-show="templateSelector.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="templateSelector.show" @keydown.esc.window="templateSelector.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="templateSelectorTitle">
        <!-- Modal Dialog -->
        <div x-show="templateSelector.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel-xl">
          <!-- Dialog Header -->
          <div class="ui-modal-header">
            <div class="ui-modal-icon-info">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75 16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z" />
              </svg>
            </div>
            <h3 id="templateSelectorTitle" class="ui-modal-title">Select a Template</h3>
            <button @click="templateSelector.show = false" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <!-- Dialog Body -->
          <div class="ui-modal-body-scroll max-h-[70vh]">
            <!-- Search and Filter -->
            <div class="mb-4">
              <input type="search" class="form-field w-full" placeholder="Search templates..." aria-label="Search templates" x-model="templateSelector.searchTerm" x-on:input="templateSearchChanged" x-ref="templateSearchInput">
            </div>

            <!-- Template List -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
              <template x-for="t in templateSelector.templates" :key="t.template_id">
                <template x-if="!t.searchHide">
                  <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer transition-colors" @click="selectTemplate(t.template_id)">
                    <div class="flex items-start gap-4">
                      <img x-show="t.icon_url && t.icon_url_exists" :src="t.icon_url" alt="Icon" class="size-12 flex-shrink-0" />

                      <div class="flex-grow min-w-0">
                        <div class="flex items-start justify-between gap-2">
                          <div class="flex-grow min-w-0">
                            <h4 class="text-base font-semibold text-gray-900 dark:text-white truncate" x-text="t.name"></h4>
                            <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2" x-text="t.description"></p>
                          </div>
                        </div>

                        <div class="flex flex-wrap gap-2 mt-2 items-center">
                          <span x-show="t.platform == 'docker'" class="app-badge-info">Docker</span>
                          <span x-show="t.platform == 'podman'" class="app-badge-info">Podman</span>
                          <span x-show="t.platform == 'apple'" class="app-badge-info">Apple</span>
                          <span x-show="t.platform == 'container'" class="app-badge-info">Container</span>
                          <span x-show="t.platform == 'nomad'" class="app-badge-success">Nomad</span>
                          <span x-show="t.platform == 'manual'" class="app-badge-warning">Manual</span>

                          <span class="text-xs text-gray-500 dark:text-gray-400">
                            <span class="font-medium">Compute:</span> <span x-text="t.compute_units"></span>
                          </span>
                          <span class="text-xs text-gray-500 dark:text-gray-400">
                            <span class="font-medium">Storage:</span> <span x-text="t.storage_units"></span>
                          </span>
                        </div>

                        <!-- Schedule indicators -->
                        <template x-if="t.schedule_enabled">
                          <div class="text-xs text-gray-500 dark:text-gray-400 mt-2">
                            <span class="font-medium">Schedule:</span>
                            <div class="flex flex-wrap gap-1 mt-1">
                              <template x-for="index in 7" :key="index">
                                <div x-show="t.schedule[index % 7].enabled" class="inline" x-data>
                                  <span @click="$refs.panel.toggle" class="inline-block bg-blue-50 text-blue-700 px-1 py-0.5 rounded-md dark:bg-blue-500/15 dark:text-blue-400 cursor-pointer" x-text="getDayOfWeek(index % 7).substring(0,3)"></span>
                                  <div x-ref="panel" x-float.teleport.placement.bottom-center.flip @click.away="$refs.panel.close" @keydown.window.escape="$refs.panel.close" class="fixed z-50 my-1 p-2 bg-white rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 block whitespace-nowrap" x-cloak>
                                    <span x-text="t.schedule[index % 7].from"></span> - <span x-text="t.schedule[index % 7].to"></span>
                                  </div>
                                </div>
                              </template>
                            </div>
                          </div>
                        </template>
                      </div>
                    </div>
                  </div>
                </template>
              </template>
            </div>
          </div>
        </div>
      </div>

      {{ if or .permissionManageStackDefinitions .permissionManageOwnStackDefinitions .permissionUseStackDefinitions .isLeafNode }}
      <!-- Modal: Stack Template Selector -->
      <div x-cloak x-show="stackDefSelector.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="stackDefSelector.show" @keydown.esc.window="stackDefSelector.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="stackDefSelectorTitle">
        <div x-show="stackDefSelector.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel-xl">
          <div class="ui-modal-header">
            <div class="ui-modal-icon-info">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3" />
              </svg>
            </div>
            <h3 id="stackDefSelectorTitle" class="ui-modal-title">Select a Stack Template</h3>
            <button @click="stackDefSelector.show = false" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="ui-modal-body-scroll max-h-[70vh]">
            <div class="mb-4">
              <input type="search" class="form-field w-full" placeholder="Search stack templates..." aria-label="Search stack templates" x-model="stackDefSelector.searchTerm" x-on:input="stackDefSearchChanged" x-ref="stackDefSearchInput">
            </div>
            <div x-show="stackDefSelector.loading" class="text-center text-sm text-gray-500 dark:text-gray-400 py-8">Loading…</div>
            <div x-show="!stackDefSelector.loading && stackDefSelector.definitions.filter(d => !d.searchHide).length === 0" class="text-center text-sm text-gray-500 dark:text-gray-400 py-8">No stack templates available.</div>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-3">
              <template x-for="d in stackDefSelector.definitions" :key="d.stack_definition_id">
                <template x-if="!d.searchHide">
                  <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer transition-colors" @click="openCreateStackFromDef(d)">
                    <div class="flex-grow min-w-0">
                      <h4 class="text-base font-semibold text-gray-900 dark:text-white truncate" x-text="d.name"></h4>
                      <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2" x-text="d.description"></p>
                      <div class="flex flex-wrap gap-2 mt-2 items-center text-xs text-gray-500 dark:text-gray-400">
                        <span x-text="(d.spaces || []).length + ' space' + ((d.spaces || []).length === 1 ? '' : 's')"></span>
                        <span x-show="!d.user_id">· Global</span>
                        <span x-show="d.user_id">· Personal</span>
                      </div>
                    </div>
                  </div>
                </template>
              </template>
            </div>
          </div>
        </div>
      </div>

      <!-- Modal: Create Stack -->
      <div x-cloak x-show="createStackModal.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="createStackModal.show" @keydown.esc.window="createStackModal.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="createStackTitle">
        <div x-show="createStackModal.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel">
          <div class="ui-modal-header">
            <div class="ui-modal-icon-info">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75 2.25 12l4.179 2.25m0-4.5 5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0 4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0-5.571 3-5.571-3" />
              </svg>
            </div>
            <h3 id="createStackTitle" class="ui-modal-title">Create Stack</h3>
            <button @click="createStackModal.show = false" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="ui-modal-body">
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">Create spaces from <strong x-text="createStackModal.def?.name || ''"></strong></p>
            <div class="mb-4">
              <label for="stackPrefix" class="block text-sm font-medium text-gray-900 dark:text-white mb-1">Prefix</label>
              <input type="text" id="stackPrefix" class="form-field w-full" placeholder="e.g. myproject" x-model="createStackModal.prefix" @keydown.enter="submitCreateStack()" x-ref="stackPrefixInput">
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Spaces will be named: <span x-text="createStackModal.prefix ? createStackModal.prefix + '-&lt;space&gt;' : '&lt;prefix&gt;-&lt;space&gt;'"></span></p>
            </div>
            <div class="mb-4">
              <label for="stackName" class="block text-sm font-medium text-gray-900 dark:text-white mb-1">Stack Name</label>
              <input type="text" id="stackName" class="form-field w-full" placeholder="Defaults to prefix" x-model="createStackModal.name" @keydown.enter="submitCreateStack()">
            </div>
            <div x-show="createStackModal.error" class="text-sm text-red-600 dark:text-red-400" x-text="createStackModal.error"></div>
            <div x-show="createStackModal.creating" class="text-sm text-gray-500 dark:text-gray-400">
              Creating spaces…
            </div>
          </div>
          <div class="ui-modal-footer">
            <button @click="createStackModal.show = false" type="button" class="btn-secondary" :disabled="createStackModal.creating">Cancel</button>
            <button @click="submitCreateStack()" type="button" class="btn-primary" :disabled="createStackModal.creating || !createStackModal.prefix">Create</button>
          </div>
        </div>
      </div>
      {{ end }}

    </div>

  </div>
</main>
{{ end }}
