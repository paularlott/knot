{{ template "layout-base.tmpl" . }}

{{ define "pageTitle" }}Spaces{{ end }}

{{ define "mainContent" }}
<main class="relative w-full h-full overflow-y-auto lg:ml-64 pb-8" x-data="spacesListComponent('{{ .user_id }}', '{{ .username }}', '{{ .forUserId }}', {{ .permissionManageSpaces }}, '{{ .wildcard_domain }}', '{{ .zone }}', {{ .permissionTransferSpaces }}, {{ .permissionShareSpaces }})">
  <div class="grid grid-cols-1 px-4 pt-6 xl:grid-cols-4 gap-2 xl:gap-4">

    <div class="mb-4 col-span-full xl:mb-2">
      <h1 class="text-xl font-semibold text-gray-900 sm:text-2xl dark:text-white">
        {{ if eq .user_id .forUserId }}
          Spaces
        {{ else }}
          Spaces for {{ .forUserUsername }}
        {{ end }}
      </h1>
    </div>

    <form class="col-span-full sm:flex justify-between">
      <div class="flex" x-data>
        <div class="w-full sm:w-auto">
          <label for="search" class="sr-only">Search</label>
          <div class="relative mt-1 sm:w-48 lg:w-64 xl:w-96 flex items-center">
            <input type="search" name="search" id="search" class="form-field grow pr-10" placeholder="Search" x-model="searchTerm" x-on:input="searchChanged">
            <div class="absolute right-2 text-sm text-gray-500 dark:text-gray-400 font-sans ml-2 text-nowrap">⌘ K</div>
          </div>
        </div>

        <button @click.prevent="$refs.panel.toggle" aria-label="Filter" class="relative text-gray-500 dark:text-gray-400 text-sm px-2.5 py-3 cursor-pointer mt-1 ml-2 hover:text-gray-700 dark:hover:text-gray-200">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z" />
          </svg>
          <span x-show="showRunningOnly || !showLocalOnly || showSharedOnly || showSharedWithMeOnly" class="absolute top-2.5 right-2 size-2 rounded-full bg-blue-500" aria-hidden="true"></span>
        </button>

        <div x-ref="panel" x-float.teleport.placement.bottom-end.flip="" @click.away="$refs.panel.close" @keydown.window.escape="$refs.panel.close" class="fixed z-50 my-1 text-base p-2 pr-4 list-none bg-white rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 block whitespace-nowrap">

          <div x-show="canManageSpaces && !showingSpecificUser" x-cloak class="mb-4">
            <div x-data="autocompleterUser()" x-init="setDataSource('forUsersList')" data-parent-group="" data-parent-variable="forUserId" data-on-change="userChagned" @refresh-user-autocompleter.window="refresh()" class="relative" @user-selected="userChanged">
              <input x-model="search" class="form-field" type="search" placeholder="Search for user..." aria-label="Search users" role="combobox" :aria-expanded="showList && filteredOptions.length > 0" :aria-activedescendant="activeDescendant" :aria-controls="_listboxId" @focus="handleFocus()" @blur.debounce.200ms="showList = false" @keydown="handleKeydown($event)" x-ref="searchInput" />
              <div x-show="showList && filteredOptions.length" x-cloak class="w-full max-h-40 overflow-auto absolute z-50 my-1 text-base p-2 list-none bg-white divide-y divide-gray-100 rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 block whitespace-nowrap">
                <ul class="list-none" role="listbox" :id="_listboxId">
                  <template x-for="(option, index) in filteredOptions" :key="index">
                    <li @click="selectOption(option)" x-text="option.username" :id="`${_listboxId}-opt-${index}`" role="option" :aria-selected="selectedIndex === index" :class="{'bg-blue-100 dark:bg-blue-900': selectedIndex === index}" class="my-1 cursor-pointer nav-item text-sm"></li>
                  </template>
                </ul>
              </div>
            </div>
          </div>

          <div class="mb-4" :class="{'mt-4': !canManageSpaces || showingSpecificUser}">
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" @change="searchChanged" class="sr-only peer" value="1" :checked="showRunningOnly" x-model="showRunningOnly">
              <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
              <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Running</span>
            </label>
          </div>

          <div class="mb-4">
            <label class="flex items-center cursor-pointer mb-4">
              <input type="checkbox" @change="searchChanged" class="sr-only peer" value="1" :checked="showLocalOnly" x-model="showLocalOnly">
              <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
              <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">In This Zone</span>
            </label>
          </div>

          <div class="mb-4">
            <label class="flex items-center cursor-pointer mb-4">
              <input type="checkbox" @change="showSharedOnly && (showSharedWithMeOnly = false); searchChanged()" class="sr-only peer" value="1" :checked="showSharedOnly" x-model="showSharedOnly">
              <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
              <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Shared</span>
            </label>
          </div>
          <div class="mb-4">
            <label class="flex items-center cursor-pointer mb-4">
              <input type="checkbox" @change="showSharedWithMeOnly && (showSharedOnly = false); searchChanged()" class="sr-only peer" value="1" :checked="showSharedWithMeOnly" x-model="showSharedWithMeOnly">
              <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
              <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Shared With Me</span>
            </label>
          </div>

        </div>

      </div>
      <div>
        <button @click.prevent="openTemplateSelector" type="button" class="btn-primary flex items-center mt-1">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4 mr-2" aria-hidden="true" >
            <path fill-rule="evenodd" d="M12 3.75a.75.75 0 0 1 .75.75v6.75h6.75a.75.75 0 0 1 0 1.5h-6.75v6.75a.75.75 0 0 1-1.5 0v-6.75H4.5a.75.75 0 0 1 0-1.5h6.75V4.5a.75.75 0 0 1 .75-.75Z" clip-rule="evenodd" />
          </svg>
          New Space
        </button>
      </div>
    </form>

    <div class="p-4 mb-4 bg-white border border-gray-200 rounded-lg shadow-xs col-span-full dark:border-gray-700 sm:p-6 dark:bg-gray-800">
      {{ template "loading" . }}

      <template x-if="!loading && (!visibleSpaces && !searchTerm.length && showLocalOnly)">
        <div class="w-full max-w-lg mx-auto p-4 bg-white border border-gray-200 rounded-lg shadow-lg dark:border-gray-700 dark:bg-gray-800">
            <div class="text-center text-gray-500 dark:text-gray-400">No spaces found.<br />Get started by <button @click.prevent="openTemplateSelector" class="text-blue-500 hover:underline dark:text-blue-400">selecting a template</button>.</div>
        </div>
      </template>

      <div x-show="!loading && (visibleSpaces || searchTerm.length)" x-cloak class="relative overflow-x-auto">
        <table aria-label="Spaces" class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
          <colgroup>
            <col class="w-1/1.1 lg:w-1/3.5 xl:w-1/3" />
            <col class="w-auto" /> <!-- Services -->
            <col class="w-auto" /> <!-- Status -->
            <col class="w-auto" /> <!-- Share -->
            <col class="w-auto" /> <!-- Template -->
            <col class="w-1" />
          </colgroup>
          <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
            <tr>
              <th scope="col" class="px-4 py-3">Details</th>
              <th scope="col" class="px-4 py-3 hidden md:table-cell">Services</th>
              <th scope="col" class="px-4 py-3 hidden lg:table-cell">Status</th>
              <th scope="col" class="px-4 py-3 hidden 2xl:table-cell">Share</th>
              <th scope="col" class="px-4 py-3 hidden xl:table-cell">Template</th>
              <th scope="col" class="px-4 py-3">&nbsp;</th>
            </tr>
          </thead>
          <!-- Unstacked spaces -->
          <tbody>
            <!-- Show header only when stacks exist -->
            <template x-if="hasStacks() && unstackedVisibleSpaces().length > 0">
              <tr class="bg-gray-50 dark:bg-gray-700/50 border-b dark:border-gray-700 cursor-pointer select-none" @click="toggleStack('')">
                <td colspan="6" class="px-4 py-2">
                  <div class="flex items-center gap-2">
                    <svg :class="{'rotate-90': !collapsedStacks[''], '-rotate-90': collapsedStacks['']}" class="size-3 text-gray-500 dark:text-gray-400 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
                    <span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Unstacked</span>
                    <span class="text-xs text-gray-500 dark:text-gray-400" x-text="'(' + unstackedVisibleSpaces().length + ' space' + (unstackedVisibleSpaces().length !== 1 ? 's' : '') + ')'"></span>
                  </div>
                </td>
              </tr>
            </template>
            <template x-for="space in unstackedVisibleSpaces()" :key="space.space_id">
              <tr x-show="!hasStacks() || !collapsedStacks['']" x-data="{ s: space }" class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600/10">
                {{ template "space-row-cells" . }}
              </tr>
            </template>
          </tbody>

          <!-- Stacked spaces - one tbody per stack -->
          <template x-for="group in stackedGroups()" :key="'stack-' + group.name">
            <tbody>
              <!-- Stack header row -->
              <tr class="bg-gray-50 dark:bg-gray-700/50 border-b dark:border-gray-700">
                <td colspan="6" class="px-4 py-2">
                  <div class="flex items-center gap-2">
                    <div class="flex items-center gap-2 cursor-pointer select-none flex-1" @click="toggleStack(group.name)">
                      <svg :class="{'rotate-90': !collapsedStacks[group.name], '-rotate-90': collapsedStacks[group.name]}" class="size-3 text-gray-500 dark:text-gray-400 transition-transform" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
                      <span class="text-sm font-semibold text-gray-700 dark:text-gray-300" x-text="group.name"></span>
                      <span class="text-xs text-gray-500 dark:text-gray-400" x-text="'(' + group.count + ' space' + (group.count !== 1 ? 's' : '') + ')'"></span>
                    </div>
                    <div class="flex items-center gap-1 ml-auto">
                      <button x-show="group.spaces.some(s => !s.is_deployed && !s.is_pending)" @click.stop="startStack(group.name)" :disabled="stackBusy[group.name] === true" type="button" class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium rounded text-white bg-green-600 hover:bg-green-700 disabled:opacity-50 disabled:cursor-not-allowed">
                        <svg x-show="stackBusy[group.name] !== true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-3" aria-hidden="true"><path fill-rule="evenodd" d="M4.5 5.653c0-1.427 1.529-2.33 2.779-1.643l11.54 6.347c1.295.712 1.295 2.573 0 3.286L7.28 19.99c-1.25.687-2.779-.217-2.779-1.643V5.653Z" clip-rule="evenodd"/></svg>
                        <svg x-show="stackBusy[group.name] === true" x-cloak class="size-3 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        Start
                      </button>
                      <button x-show="group.spaces.some(s => s.is_deployed || s.is_pending)" @click.stop="stopStack(group.name)" :disabled="stackBusy[group.name] === true" type="button" class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium rounded text-white bg-red-600 hover:bg-red-700 disabled:opacity-50 disabled:cursor-not-allowed">
                        <svg x-show="stackBusy[group.name] !== true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-3" aria-hidden="true"><path fill-rule="evenodd" d="M4.5 7.5a3 3 0 0 1 3-3h9a3 3 0 0 1 3 3v9a3 3 0 0 1-3 3h-9a3 3 0 0 1-3-3v-9Z" clip-rule="evenodd"/></svg>
                        <svg x-show="stackBusy[group.name] === true" x-cloak class="size-3 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        Stop
                      </button>
                      <button x-show="group.spaces.every(s => s.is_deployed)" @click.stop="restartStack(group.name)" :disabled="stackBusy[group.name] === true" type="button" class="inline-flex items-center gap-1 px-2 py-1 text-xs font-medium rounded text-white bg-blue-600 hover:bg-blue-700 disabled:opacity-50 disabled:cursor-not-allowed">
                        <svg x-show="stackBusy[group.name] !== true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-3" aria-hidden="true"><path fill-rule="evenodd" d="M4.755 10.059a7.5 7.5 0 0 1 12.548-3.364l1.903 1.903h-3.183a.75.75 0 1 0 0 1.5h4.992a.75.75 0 0 0 .75-.75V4.356a.75.75 0 0 0-1.5 0v3.18l-1.9-1.9A9 9 0 0 0 3.306 9.67a.75.75 0 1 0 1.45.388Zm15.408 3.352a.75.75 0 0 0-.919.53 7.5 7.5 0 0 1-12.548 3.364l-1.902-1.903h3.183a.75.75 0 0 0 0-1.5H2.984a.75.75 0 0 0-.75.75v4.992a.75.75 0 0 0 1.5 0v-3.18l1.9 1.9a9 9 0 0 0 15.059-4.035.75.75 0 0 0-.53-.918Z" clip-rule="evenodd"/></svg>
                        <svg x-show="stackBusy[group.name] === true" x-cloak class="size-3 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg>
                        Restart
                      </button>
                    </div>
                  </div>
                </td>
              </tr>
              <!-- Space rows in this stack -->
              <template x-for="space in group.spaces" :key="space.space_id">
                <tr x-show="!collapsedStacks[group.name]" x-data="{ s: space }" class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600/10">
                  {{ template "space-row-cells" . }}
                </tr>
              </template>
            </tbody>
          </template>
        </table>
      </div>

      <!-- Modal choose user -->
      <div x-cloak x-show="chooseUser.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="chooseUser.show" @keydown.esc.window="chooseUser.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="chooseUserTitle">
        <!-- Modal Dialog -->
        <div x-show="chooseUser.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel overflow-visible">
          <!-- Dialog Header -->
          <div class="ui-modal-header">
            <div x-cloak x-show="!chooseUser.isShare" class="ui-modal-icon-danger">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true" >
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"></path>
              </svg>
            </div>
            <div x-cloak x-show="chooseUser.isShare" class="ui-modal-icon-info">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true" >
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z" />
              </svg>
            </div>
            <h3 id="chooseUserTitle" class="ui-modal-title" x-text="chooseUser.isShare ? 'Share Space With' : 'Transfer Space To'"></h3>
            <button @click="chooseUser.show = false;" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <!-- Dialog Body -->
          <div class="ui-modal-body">
            <p x-cloak x-show="!chooseUser.isShare">Select the user to transfer the space to.</p>
            <p x-cloak x-show="chooseUser.isShare">Select the user to share the space with.</p>
            <div x-data="autocompleterUser()" x-init="setDataSource('shareUsers')" data-parent-var-group="chooseUser" data-parent-variable="toUserId" data-parent-variable-username="toUserUsername" @refresh-autocompleter.window="refresh()" class="relative mt-2">
              <input x-model="search" class="form-field" type="search" placeholder="Search for user..." aria-label="Search users" role="combobox" :aria-expanded="showList && filteredOptions.length > 0" :aria-activedescendant="activeDescendant" :aria-controls="_listboxId" @focus="handleFocus()" @blur.debounce.200ms="showList = false" @keydown="handleKeydown($event)" x-ref="searchInput" x-init="$nextTick(() => $refs.searchInput.focus())" autofocus>
              <div x-show="showList && filteredOptions.length" x-cloak class="w-full max-h-40 overflow-auto absolute z-50 my-1 text-base p-2 list-none bg-white divide-y divide-gray-100 rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 block whitespace-nowrap">
                <ul class="list-none" role="listbox" :id="_listboxId">
                  <template x-for="(option, index) in filteredOptions" :key="index">
                    <li @click="selectOption(option)" :id="`${_listboxId}-opt-${index}`" role="option" :aria-selected="selectedIndex === index" :class="{'bg-blue-100 dark:bg-blue-900': selectedIndex === index}" class="my-1 cursor-pointer nav-item text-sm">
                      {{ if .useGravatar }}
                      <img :src="`https://www.gravatar.com/avatar/${MD5(option.email)}?s=64&d=mp`" alt="User Avatar" class="size-5 rounded-full mr-2">
                      {{ end }}
                      <div x-text="option.username"></div>
                    </li>
                  </template>
                </ul>
              </div>
            </div>
            <div x-show="chooseUser.invalidUser" class="error-message" x-cloak>Select a valid user.</div>

          </div>
          <!-- Dialog Footer -->
          <div class="ui-modal-footer">
              <button @click="chooseUser.show = false" type="button" class="ui-button-secondary">Cancel</button>
              <button x-show="!chooseUser.isShare && chooseUser.toUserId != ''" x-cloak @click="transferSpaceTo" type="button" class="ui-button-danger">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 mr-2" aria-hidden="true" >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"></path>
                </svg> <span x-text="'Transfer Space to ' + chooseUser.toUserUsername"></span>
              </button>
              <button x-show="chooseUser.isShare && chooseUser.toUserId != ''" x-cloak @click="transferSpaceTo" type="button" class="ui-button-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 mr-2" aria-hidden="true" >
