{{ template "layout-base.tmpl" . }}

{{ define "pageTitle" }}Events{{ end }}

{{ define "mainContent" }}
<main class="relative w-full h-full overflow-y-auto lg:ml-64 pb-8" x-data="eventSinkListComponent('{{ .user_id }}', {{ .permissionManageEvents }}, {{ .permissionManageGlobalEvents }}, {{ .isLeafNode }})">
  <div class="grid grid-cols-1 px-4 pt-6 xl:grid-cols-4 gap-2 xl:gap-4">

    <div class="col-span-full">
      <h1 class="text-xl font-semibold text-gray-900 sm:text-2xl dark:text-white">Events</h1>
    </div>

    <form class="app-toolbar col-span-full">
      <div class="flex" x-data>
        <div class="w-full sm:w-auto">
          <label for="search" class="sr-only">Search</label>
          <div class="relative mt-1 sm:w-48 lg:w-64 xl:w-96 flex items-center">
            <input type="search" name="search" id="search" class="form-field grow pr-24 app-page-search" placeholder="Search" x-model="searchTerm" x-on:input="searchChanged" x-ref="searchInput">
            <button type="button" x-show="searchTerm" x-cloak @click="searchTerm=''; searchChanged(); $refs.searchInput.focus()" aria-label="Clear search" class="app-search-clear"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/></svg></button><div class="app-search-shortcut">⌘ K</div>
          </div>
        </div>
        <button @click.prevent="$refs.panel.toggle" aria-label="Filter" class="relative text-gray-500 dark:text-gray-400 text-sm px-2.5 py-3 cursor-pointer ml-2 hover:text-gray-700 dark:hover:text-gray-200">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z" />
          </svg>
          <span x-show="!showMySinks || showGlobalSinks" class="absolute top-2.5 right-2 size-2 rounded-full bg-blue-500" aria-hidden="true"></span>
        </button>

        <div x-ref="panel" x-float.teleport.placement.bottom-end.flip @click.away="$refs.panel.close" @keydown.window.escape="$refs.panel.close" class="fixed z-50 my-1 text-base p-2 pr-4 list-none bg-white rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 block whitespace-nowrap" x-cloak>
          {{ if or .isLeafNode .permissionManageEvents }}
          <div class="mb-2 mt-2">
            <label class="flex items-center cursor-pointer mb-2">
              <input type="checkbox" class="sr-only peer" @change="filterChanged" :checked="showMySinks" x-model="showMySinks">
              <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
              <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">My Event Sinks</span>
            </label>
          </div>
          {{ end }}
          {{ if or .isLeafNode .permissionManageGlobalEvents }}
          <div class="mb-2 mt-4">
            <label class="flex items-center cursor-pointer mb-2">
              <input type="checkbox" class="sr-only peer" @change="filterChanged" :checked="showGlobalSinks" x-model="showGlobalSinks">
              <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
              <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Global Event Sinks</span>
            </label>
          </div>
          {{ end }}
        </div>
      </div>
      <div class="flex gap-2">
        {{ if or .isLeafNode .permissionManageEvents }}
        <button @click.prevent="createSink(false)" class="btn-primary flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4 mr-2" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 3.75a.75.75 0 0 1 .75.75v6.75h6.75a.75.75 0 0 1 0 1.5h-6.75v6.75a.75.75 0 0 1-1.5 0v-6.75H4.5a.75.75 0 0 1 0-1.5h6.75V4.5a.75.75 0 0 1 .75-.75Z" clip-rule="evenodd" />
          </svg>
          My Sink
        </button>
        {{ end }}
        {{ if or .isLeafNode .permissionManageGlobalEvents }}
        <button @click.prevent="createSink(true)" class="btn-primary flex items-center">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-4 mr-2" aria-hidden="true">
            <path fill-rule="evenodd" d="M12 3.75a.75.75 0 0 1 .75.75v6.75h6.75a.75.75 0 0 1 0 1.5h-6.75v6.75a.75.75 0 0 1-1.5 0v-6.75H4.5a.75.75 0 0 1 0-1.5h6.75V4.5a.75.75 0 0 1 .75-.75Z" clip-rule="evenodd" />
          </svg>
          Global Sink
        </button>
        {{ end }}
      </div>
    </form>

    {{ template "filterBar" (map "active" "!showMySinks || showGlobalSinks") }}
      {{ template "filterChip" (map "show" "!showMySinks" "label" "My Event Sinks off" "click" "showMySinks=true; filterChanged()") }}
      {{ template "filterChip" (map "show" "showGlobalSinks" "label" "Global Event Sinks" "click" "showGlobalSinks=false; filterChanged()") }}
    {{ template "filterBarClear" (map "clear" "showMySinks=true; showGlobalSinks=false; filterChanged()") }}

    <div class="p-4 mb-4 bg-white border border-gray-200 rounded-lg shadow-xs col-span-full dark:border-gray-700 sm:p-6 dark:bg-gray-800">
      {{ template "loading" . }}
      <div x-show="!loading" x-cloak class="relative overflow-x-auto">
        <table aria-label="Event Sinks" class="w-full text-sm text-left rtl:text-right">
          <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
            <tr>
              <th scope="col" class="px-4 py-3">Name & Description</th>
              <th scope="col" class="px-4 py-3 hidden md:table-cell">Owner</th>
              <th scope="col" class="px-4 py-3 hidden md:table-cell">Type</th>
              <th scope="col" class="px-4 py-3 hidden lg:table-cell">Events</th>
              <th scope="col" class="px-4 py-3 hidden md:table-cell">Status</th>
              <th scope="col" class="px-4 py-3">&nbsp;</th>
            </tr>
          </thead>
          <tbody>
            <template x-for="s in sinks" :key="s.event_sink_id">
              <template x-if="!s.searchHide">
                <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600/10">
                  <td class="px-4 py-3">
                    <div class="text-base font-semibold text-gray-900 dark:text-white" x-text="s.name"></div>
                    <div class="text-xs text-gray-500 dark:text-gray-400" x-text="s.description"></div>
                  </td>
                  <td class="px-4 py-3 align-middle hidden md:table-cell">
                    <span x-show="!s.user_id" class="app-badge-purple">Global</span>
                    <span x-show="s.user_id" class="app-badge-info">User</span>
                  </td>
                  <td class="px-4 py-3 align-middle hidden md:table-cell">
                    <span x-show="s.sink_type === 'webhook'" class="app-badge-info">Webhook</span>
                    <span x-show="s.sink_type === 'script'" class="app-badge-neutral">Script</span>
                    <span x-show="s.sink_type === 'json-rpc'" class="app-badge-success">JSON-RPC</span>
                  </td>
                  <td class="px-4 py-3 align-middle hidden lg:table-cell">
                    <template x-if="s.events && s.events.length">
                      <div>
                        <div class="flex flex-wrap gap-1">
                          <template x-for="(pattern, index) in s.events" :key="index">
                            <span class="app-badge-warning" x-text="pattern"></span>
                          </template>
                        </div>
                      </div>
                    </template>
                    <template x-if="!s.events || !s.events.length">
                      <span class="text-xs text-gray-500 dark:text-gray-400">-</span>
                    </template>
                  </td>
                  <td class="px-4 py-3 align-middle hidden md:table-cell">
                    <span x-show="s.active" class="app-badge-success">Active</span>
                    <span x-show="!s.active" class="app-badge-neutral">Inactive</span>
                  </td>
                  <td class="px-4 py-3 align-middle">
                    <div class="flex items-center justify-end" x-data x-show="canEditSink(s)">
                      <div class="hidden xl:flex items-center justify-end gap-2" aria-label="Event sink actions">
                        <button @click="editSink(s.event_sink_id)" class="row-action-button" type="button" :aria-label="'Edit event sink ' + s.name" title="Edit">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                          </svg>
                          <span class="sr-only">Edit</span>
                        </button>
                        <template x-if="canDeleteSink(s)">
                          <button @click="deleteConfirm.show = true; deleteConfirm.sink = s" class="row-action-button row-action-danger" type="button" :aria-label="'Delete event sink ' + s.name" title="Delete">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                            </svg>
                            <span class="sr-only">Delete</span>
                          </button>
                        </template>
                      </div>
                      <button @click="$refs.panel.toggle" class="row-action-menu-trigger xl:hidden" type="button" :aria-label="'More actions for event sink ' + s.name" aria-haspopup="menu">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5" aria-hidden="true">
                          <path fill-rule="evenodd" d="M10.5 6a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0Zm0 6a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0Zm0 6a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0Z" clip-rule="evenodd" />
                        </svg><span class="sr-only">More</span>
                      </button>

                      <div x-ref="panel" x-float.teleport.placement.bottom-end.flip @click.away="$refs.panel.close" @keydown.window.escape="$refs.panel.close" class="fixed z-50 my-1 text-base p-2 list-none bg-white divide-y divide-gray-100 rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 block whitespace-nowrap xl:hidden" role="menu" x-cloak>
                        <button @click="$refs.panel.close; editSink(s.event_sink_id)" class="group nav-item text-sm px-4 w-full" role="menuitem">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 mr-2" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
                          </svg> Edit
                        </button>
                        <template x-if="canDeleteSink(s)">
                          <hr class="my-2" />
                        </template>
                        <template x-if="canDeleteSink(s)">
                          <button @click="$refs.panel.close; deleteConfirm.show = true; deleteConfirm.sink = s" class="group nav-item text-sm px-4 w-full text-red-700 hover:bg-red-50 hover:text-red-800 dark:text-red-400 dark:hover:bg-red-900/30 dark:hover:text-red-300" role="menuitem">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 mr-2" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                            </svg> Delete
                          </button>
                        </template>
                      </div>
                    </div>
                  </td>
                </tr>
              </template>
            </template>
          </tbody>
        </table>
      </div>

      <!-- Delete Modal -->
      <div x-cloak x-show="deleteConfirm.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="deleteConfirm.show" @keydown.esc.window="deleteConfirm.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="deleteConfirmTitle">
        <div x-show="deleteConfirm.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel">
          <div class="ui-modal-header">
            <div class="ui-modal-icon-danger">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
              </svg>
            </div>
            <h3 id="deleteConfirmTitle" class="ui-modal-title">Confirm Delete</h3>
            <button @click="deleteConfirm.show = false" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="ui-modal-body text-center">
            <p>Are you sure you want to delete the event sink <strong x-text="deleteConfirm.sink.name"></strong>?</p>
          </div>
          <div class="ui-modal-footer">
            <button @click="deleteConfirm.show = false" type="button" class="ui-button-secondary">Keep Sink</button>
            <button @click="deleteSink(deleteConfirm.sink.event_sink_id); deleteConfirm.show = false" type="button" class="ui-button-danger">Delete Sink</button>
          </div>
        </div>
      </div>

      <!-- Edit/Create Modal -->
      <div x-cloak x-show="sinkFormModal.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="sinkFormModal.show" @keydown.esc.window="sinkFormModal.show = false" @close-event-sink-form.window="sinkFormModal.show = false; getEventSinks()" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="sinkModalTitle">
        <div x-show="sinkFormModal.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel-2xl max-h-[90vh]">
          <div class="ui-modal-header">
            <div class="ui-modal-icon-info">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
              </svg>
            </div>
            <h3 id="sinkModalTitle" class="ui-modal-title" x-text="sinkFormModal.isEdit ? 'Edit Event Sink' : 'Create Event Sink'"></h3>
            <button @click="sinkFormModal.show = false" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <template x-if="sinkFormModal.show">
            <div class="ui-modal-body-scroll">
              {{ template "event-sink-form-content" . }}
            </div>
          </template>
        </div>
      </div>

    </div>
  </div>
</main>
{{ end }}
