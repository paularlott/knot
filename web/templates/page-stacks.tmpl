{{ template "layout-base.tmpl" . }}

{{ define "pageTitle" }}Stacks{{ end }}

{{ define "mainContent" }}
<main class="relative w-full h-full overflow-y-auto lg:ml-64 pb-8" x-data="stackListComponent('{{ .user_id }}', '{{ .zone }}', {{ .permissionManageStackDefinitions }}, {{ .isLeafNode }}, {{ .permissionUseSpaces }})" data-zone="{{ .zone }}">
  <div class="grid grid-cols-1 px-4 pt-6 xl:grid-cols-4 gap-2 xl:gap-4">

    <div class="mb-4 col-span-full xl:mb-2">
      <h1 class="text-xl font-semibold text-gray-900 sm:text-2xl dark:text-white">Stacks</h1>
    </div>

    <form class="app-toolbar col-span-full">
      <div class="flex" x-data>
        <div class="w-full sm:w-auto">
          <label for="search" class="sr-only">Search</label>
          <div class="relative mt-1 sm:w-48 lg:w-64 xl:w-96 flex items-center">
            <input type="search" name="search" id="search" class="form-field grow pr-10" placeholder="Search" x-model="searchTerm" x-on:input="searchChanged">
            <div class="app-search-shortcut">⌘ K</div>
          </div>
        </div>
        <button @click.prevent="$refs.panel.toggle" aria-label="Filter" class="relative text-gray-500 dark:text-gray-400 text-sm px-2.5 py-3 cursor-pointer ml-2 hover:text-gray-700 dark:hover:text-gray-200">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 0 1-.659 1.591l-5.432 5.432a2.25 2.25 0 0 0-.659 1.591v2.927a2.25 2.25 0 0 1-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 0 0-.659-1.591L3.659 7.409A2.25 2.25 0 0 1 3 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0 1 12 3Z" />
          </svg>
          <span x-show="!showMyDefs || !showGlobalDefs || showAllZones" class="absolute top-2.5 right-2 size-2 rounded-full bg-blue-500" aria-hidden="true"></span>
        </button>

        <div x-ref="panel" x-float.teleport.placement.bottom-end.flip @click.away="$refs.panel.close" @keydown.window.escape="$refs.panel.close" class="fixed z-50 my-1 text-base p-2 pr-4 list-none bg-white rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 block whitespace-nowrap" x-cloak>
          {{ if or .isLeafNode .permissionManageOwnStackDefinitions }}
          <div class="mb-2 mt-2">
            <label class="flex items-center cursor-pointer mb-2">
              <input type="checkbox" class="sr-only peer" @change="filterChanged" x-model="showMyDefs">
              <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
              <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">My Stacks</span>
            </label>
          </div>
          {{ end }}
          {{ if or .isLeafNode .permissionManageStackDefinitions }}
          <div class="mb-2">
            <label class="flex items-center cursor-pointer mb-2">
              <input type="checkbox" class="sr-only peer" @change="filterChanged" x-model="showGlobalDefs">
              <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
              <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Global Stacks</span>
            </label>
          </div>
          {{ end }}
          {{ if not .isLeafNode }}
          <div class="mb-2 mt-4">
            <label class="flex items-center cursor-pointer mb-2">
              <input type="checkbox" class="sr-only peer" @change="showAllZonesChanged" x-model="showAllZones">
              <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
              <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Show All Zones</span>
            </label>
          </div>
          {{ end }}
        </div>
      </div>
    </form>

    <div class="p-4 mb-4 bg-white border border-gray-200 rounded-lg shadow-xs col-span-full dark:border-gray-700 sm:p-6 dark:bg-gray-800">
      {{ template "loading" . }}
      <div x-show="!loading" x-cloak class="relative overflow-x-auto">
        <table aria-label="Stack Definitions" class="w-full text-sm text-left rtl:text-right">
          <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
            <tr>
              <th scope="col" class="px-4 py-3">Name & Description</th>
              <th scope="col" class="px-4 py-3 hidden md:table-cell">Owner</th>
              <th scope="col" class="px-4 py-3 hidden md:table-cell">Status</th>
              <th scope="col" class="px-4 py-3 hidden md:table-cell">Spaces</th>
              <th scope="col" class="px-4 py-3 hidden lg:table-cell" x-show="!isLeafNode">Zones</th>
              <th scope="col" class="px-4 py-3 hidden xl:table-cell">Groups</th>
              <th scope="col" class="px-4 py-3">&nbsp;</th>
            </tr>
          </thead>
          <tbody>
            <template x-for="d in definitions" :key="d.stack_definition_id">
              <template x-if="!d.searchHide">
                <tr class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600/10">
                  <td class="px-4 py-3">
                    <div class="text-base font-semibold text-gray-900 dark:text-white" x-text="d.name"></div>
                    <div class="text-xs text-gray-500 dark:text-gray-400" x-text="d.description"></div>
                  </td>
                  <td class="px-4 py-3 hidden md:table-cell">
                    <span x-show="!d.user_id" class="inline-block w-fit bg-purple-100 text-purple-800 text-xs font-medium px-2 py-0.5 rounded-sm dark:bg-gray-700 dark:text-purple-400 border border-purple-400">Global</span>
                    <span x-show="d.user_id" class="inline-block w-fit bg-blue-100 text-blue-800 text-xs font-medium px-2 py-0.5 rounded-sm dark:bg-gray-700 dark:text-blue-400 border border-blue-400">User</span>
                    <span x-show="d.is_managed" class="inline-block w-fit bg-gray-100 text-gray-800 text-xs font-medium px-2 py-0.5 rounded-sm dark:bg-gray-700 dark:text-gray-400 border border-gray-400 ml-1" title="Managed by parent server">📡</span>
                  </td>
                  <td class="px-4 py-3 hidden md:table-cell">
                    <span x-show="d.active" class="inline-block w-fit bg-green-100 text-green-800 text-xs font-medium px-2 py-0.5 rounded-sm dark:bg-gray-700 dark:text-green-400 border border-green-400">Active</span>
                    <span x-show="!d.active" class="inline-block w-fit bg-gray-100 text-gray-800 text-xs font-medium px-2 py-0.5 rounded-sm dark:bg-gray-700 dark:text-gray-400 border border-gray-400">Inactive</span>
                  </td>
                  <td class="px-4 py-3 hidden md:table-cell">
                    <span class="text-sm text-gray-900 dark:text-white" x-text="(d.spaces || []).length"></span>
                  </td>
                  <td class="px-4 py-3 hidden lg:table-cell" x-show="!isLeafNode">
                    <template x-if="d.zones && d.zones.length">
                      <div>
                        <div class="flex flex-wrap gap-1">
                          <template x-for="zone in d.zones">
                            <span class="inline-block bg-cyan-100 text-cyan-800 text-xs font-medium px-1.5 py-0.5 rounded-sm dark:bg-gray-700 dark:text-cyan-300 border border-cyan-300 whitespace-nowrap" x-text="zone"></span>
                          </template>
                        </div>
                      </div>
                    </template>
                    <template x-if="!d.zones || !d.zones.length">
                      <span class="text-xs text-gray-500 dark:text-gray-400">All</span>
                    </template>
                  </td>
                  <td class="px-4 py-3 hidden xl:table-cell">
                    <template x-if="d.group_names && d.group_names.length">
                      <div>
                        <div class="flex flex-wrap gap-1">
                          <template x-for="group in d.group_names">
                            <span class="inline-block bg-yellow-100 text-yellow-800 text-xs font-medium px-1.5 py-0.5 rounded-sm dark:bg-gray-700 dark:text-yellow-300 border border-yellow-300 whitespace-nowrap" x-text="group"></span>
                          </template>
                        </div>
                      </div>
                    </template>
                    <template x-if="!d.group_names || !d.group_names.length">
                      <span class="text-xs text-gray-500 dark:text-gray-400">-</span>
                    </template>
                  </td>
                  <td class="px-4 py-3">
                    <div class="flex items-center justify-end" x-data x-show="canUseDef(d)">
                      <button @click="$refs.defPanel.toggle" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-hidden focus-visible:ring-2 focus-visible:ring-blue-500 rounded-lg text-sm p-2.5 cursor-pointer">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-5" aria-hidden="true">
                          <path fill-rule="evenodd" d="M10.5 6a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0Zm0 6a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0Zm0 6a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0Z" clip-rule="evenodd" />
                        </svg><span class="sr-only">More</span>
                      </button>

                      <div x-ref="defPanel" x-float.teleport.placement.bottom-end.flip @click.away="$refs.defPanel.close" @keydown.window.escape="$refs.defPanel.close" class="fixed z-50 my-1 text-base p-2 list-none bg-white divide-y divide-gray-100 rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 block whitespace-nowrap" x-cloak>
                        <button @click="$refs.defPanel.close; openCreateStack(d)" class="group nav-item text-sm px-4 w-full" role="menuitem">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 mr-2" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                          </svg> Create Stack
                        </button>
                        <template x-if="canDeleteDef(d)">
                          <hr class="my-2" />
                        </template>
                        <template x-if="canDeleteDef(d)">
                          <button @click="$refs.defPanel.close; deleteDefConfirm.show = true; deleteDefConfirm.def = d" class="group nav-item text-sm px-4 w-full text-white bg-red-700 hover:bg-red-800 dark:bg-red-600 dark:hover:bg-red-700" role="menuitem">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 mr-2" aria-hidden="true">
                              <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                            </svg> Delete
                          </button>
                        </template>
                      </div>
                    </div>
                  </td>
                </tr>
              </template>
            </template>
          </tbody>
        </table>
      </div>

      <!-- Delete Definition Modal -->
      <div x-cloak x-show="deleteDefConfirm.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="deleteDefConfirm.show" @keydown.esc.window="deleteDefConfirm.show = false" @click.self="deleteDefConfirm.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="deleteDefTitle">
        <div x-show="deleteDefConfirm.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel">
          <div class="ui-modal-header">
            <div class="ui-modal-icon-danger">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
              </svg>
            </div>
            <h3 id="deleteDefTitle" class="ui-modal-title">Confirm Delete</h3>
            <button @click="deleteDefConfirm.show = false" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="ui-modal-body text-center">
            <p>Are you sure you want to delete the stack definition <strong x-text="deleteDefConfirm.def.name"></strong>?</p>
          </div>
          <div class="ui-modal-footer">
            <button @click="deleteDefConfirm.show = false" type="button" class="ui-button-secondary">Keep Definition</button>
            <button @click="deleteDefinition(deleteDefConfirm.def.stack_definition_id); deleteDefConfirm.show = false" type="button" class="ui-button-danger">Delete Definition</button>
          </div>
        </div>
      </div>

      <!-- Create Stack Modal -->
      <div x-cloak x-show="createStackModal.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="createStackModal.show" @keydown.esc.window="createStackModal.show = false" @click.self="createStackModal.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="createStackTitle">
        <div x-show="createStackModal.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel">
          <div class="ui-modal-header">
            <div class="ui-modal-icon-info">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </div>
            <h3 id="createStackTitle" class="ui-modal-title">Create Stack</h3>
            <button @click="createStackModal.show = false" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="ui-modal-body space-y-4">
            <p class="text-sm text-gray-500 dark:text-gray-400">Create spaces from <strong x-text="createStackModal.def?.name || ''"></strong></p>
            <div>
              <label for="stackPrefix" class="block text-sm font-medium text-gray-900 dark:text-white mb-1">Prefix</label>
              <input type="text" id="stackPrefix" class="form-field w-full" placeholder="e.g. myproject" x-model="createStackModal.prefix" @keydown.enter="createStackFromDef()">
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Spaces will be named: <span x-text="createStackModal.prefix ? createStackModal.prefix + '-&lt;space&gt;' : '&lt;prefix&gt;-&lt;space&gt;'"></span></p>
            </div>
            <div>
              <label for="stackName" class="block text-sm font-medium text-gray-900 dark:text-white mb-1">Stack Name</label>
              <input type="text" id="stackName" class="form-field w-full" placeholder="Defaults to prefix" x-model="createStackModal.name" @keydown.enter="createStackFromDef()">
            </div>
            <div x-show="createStackModal.error" class="text-sm text-red-600 dark:text-red-400" x-text="createStackModal.error"></div>
            <div x-show="createStackModal.creating" class="text-sm text-gray-500 dark:text-gray-400">
              <span class="inline-block animate-spin mr-1">⟳</span> Creating spaces...
            </div>
          </div>
          <div class="ui-modal-footer">
            <button @click="createStackModal.show = false" type="button" class="ui-button-secondary" :disabled="createStackModal.creating">Cancel</button>
            <button @click="createStackFromDef()" type="button" class="ui-button-primary" :disabled="createStackModal.creating || !createStackModal.prefix">Create</button>
          </div>
        </div>
      </div>

    </div>
  </div>
</main>
{{ end }}
