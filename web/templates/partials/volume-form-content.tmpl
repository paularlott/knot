{{ define "volume-form-content" }}
<div x-data="volumeForm(volumeFormModal.isEdit, volumeFormModal.volumeId)" x-init="initData()">
  {{ template "loading" . }}
  <form class="space-y-6" x-show="!loading" x-cloak @submit.prevent="submitData">
    <div>
      <label for="name" class="form-label">Name</label>
      <input type="text" class="form-field" name="name" id="name" x-on:keyup.debounce.500ms="checkName()" :class="{'form-field-error': !nameValid}" placeholder="Volume name" x-model="formData.name">
      <div x-show="!nameValid" class="error-message" x-cloak>Volume name can be a max 64 characters.</div>
    </div>
    <div class="mb-4">
      <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Platform</label>
      <div class="flex items-center space-x-2 p-2 bg-gray-100 dark:bg-gray-700 rounded-lg w-fit">
        <label class="relative">
          <input type="radio" name="platform" id="platform-nomad-edit" value="nomad" x-model="formData.platform" class="sr-only peer" x-show="volumeFormModal.isEdit" @change="showPlatformWarning = true; onPlatformChange()">
          <input type="radio" name="platform" id="platform-nomad-new" value="nomad" x-model="formData.platform" class="sr-only peer" x-show="!volumeFormModal.isEdit" @change="onPlatformChange()">
          <div class="select-none cursor-pointer px-2 sm:px-4 py-2 rounded-lg text-sm font-medium peer-checked:bg-blue-600 peer-checked:text-white peer-focus:ring-2 peer-focus:ring-blue-300 transition-colors duration-200 ease-in-out text-gray-700 dark:text-gray-200 peer-checked:dark:text-white hover:bg-gray-200 hover:text-gray-700 hover:peer-checked:bg-blue-600 hover:peer-checked:text-white hover:dark:bg-gray-600 hover:dark:text-white hover:dark:peer-checked:bg-blue-600">Nomad</div>
        </label>
        <div class="relative inline-flex" x-data="{ open: false, isLocalContainer() { return ['docker', 'podman', 'apple', 'container'].includes(formData.platform); } }">
          <label class="relative group">
            <input type="radio" name="platform" id="platform-container" :value="isLocalContainer() ? formData.platform : 'container'" :checked="isLocalContainer()" @change="if (!isLocalContainer()) formData.platform = 'container'; if (volumeFormModal.isEdit) showPlatformWarning = true; onPlatformChange()" class="sr-only peer">
            <div class="select-none cursor-pointer px-2 sm:px-4 py-2 rounded-l-lg text-sm font-medium transition-colors duration-200 ease-in-out" :class="isLocalContainer() ? 'bg-blue-600 text-white peer-focus:ring-2 peer-focus:ring-blue-300 group-hover:bg-blue-500' : 'text-gray-700 dark:text-gray-200 group-hover:bg-gray-200 group-hover:dark:bg-gray-600'">
              <span x-text="formData.platform === 'docker' ? 'Docker' : formData.platform === 'podman' ? 'Podman' : formData.platform === 'apple' ? 'Apple' : 'Local Container'"></span>
            </div>
          </label>
          <button type="button" @click="open = !open" @click.away="open = false" aria-label="Select container platform" class="px-2 py-2 rounded-r-lg text-sm font-medium border-l transition-colors duration-200 ease-in-out" :class="isLocalContainer() ? 'bg-blue-600 text-white border-blue-700 dark:border-blue-500 hover:bg-blue-500' : 'bg-transparent text-gray-700 dark:text-gray-200 border-gray-300 dark:border-gray-600 hover:bg-gray-200 hover:dark:bg-gray-600'">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div x-show="open" x-cloak class="absolute top-full mt-1 right-0 z-50 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl min-w-[160px]">
            <div class="p-1">
              <button type="button" @click="formData.platform = 'container'; open = false; if (volumeFormModal.isEdit) showPlatformWarning = true; onPlatformChange()" class="w-full text-left px-3 py-2 text-sm rounded hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200">Local Container</button>
              <button type="button" @click="formData.platform = 'docker'; open = false; if (volumeFormModal.isEdit) showPlatformWarning = true; onPlatformChange()" class="w-full text-left px-3 py-2 text-sm rounded hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200">Docker</button>
              <button type="button" @click="formData.platform = 'podman'; open = false; if (volumeFormModal.isEdit) showPlatformWarning = true; onPlatformChange()" class="w-full text-left px-3 py-2 text-sm rounded hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200">Podman</button>
              <button type="button" @click="formData.platform = 'apple'; open = false; if (volumeFormModal.isEdit) showPlatformWarning = true; onPlatformChange()" class="w-full text-left px-3 py-2 text-sm rounded hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200">Apple</button>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div x-show="availableNodes.length > 0 && formData.platform !== 'nomad'" x-cloak>
      <label for="vol_node" class="form-label">Server</label>
      <div x-show="loadingNodes" class="text-sm text-gray-500 dark:text-gray-400">Loading servers...</div>
      <select x-show="!loadingNodes" class="form-field" name="vol_node" id="vol_node"
        :value="formData.node_id"
        @change="formData.node_id = $event.target.value"
        :disabled="isEdit && formData.active">
        <option value="">Auto-select</option>
        <template x-for="node in availableNodes" :key="node.node_id">
          <option :value="node.node_id" :selected="node.node_id === formData.node_id" x-text="node.hostname"></option>
        </template>
      </select>
      <div class="description">The server where this volume will run.</div>
    </div>
    <div>
      <label for="vol" class="form-label">Volume Definition (YAML)</label>
      <div class="mid-editor">
        <div :class="{'form-field-error': !volValid, 'editor-wrap': true}" id="vol">
          <textarea name="vol" class="form-field"></textarea>
        </div>
      </div>
      <template x-if="!volValid && !specErrors.length">
        <div class="error-message" x-cloak>Volume definition is required.</div>
      </template>
      <template x-if="specErrors.length">
        <div class="mt-2 space-y-1">
          <template x-for="(error, index) in specErrors" :key="`vol-${index}`">
            <div class="error-message" x-text="error"></div>
          </template>
        </div>
      </template>
    </div>
    <div class="flex justify-between gap-2 pt-4 border-t border-neutral-300 dark:border-gray-700">
      <button type="button" @click="volumeFormModal.show = false" class="cursor-pointer whitespace-nowrap rounded-lg px-4 py-2 text-center text-sm font-medium tracking-wide text-neutral-600 transition hover:bg-gray-100 dark:text-neutral-300 dark:hover:bg-gray-700" x-text="isEdit ? 'Discard' : 'Cancel'"></button>
      <button type="submit" class="btn-primary" :disabled="loading" x-text="isEdit ? 'Save' : 'Create'"></button>
    </div>
  </form>
  <div x-cloak x-show="showPlatformWarning" x-transition.opacity.duration.200ms x-trap.inert.noscroll="showPlatformWarning" @keydown.esc.window="showPlatformWarning = false" @click.self="showPlatformWarning = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="platformWarningTitle">
    <div x-show="showPlatformWarning" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel">
      <div class="ui-modal-header">
        <div class="ui-modal-icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6" aria-hidden="true" >
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
          </svg>
        </div>
        <h3 id="platformWarningTitle" class="ui-modal-title">Platform Changed</h3>
        <button @click="showPlatformWarning = false" aria-label="close modal" class="ui-modal-close">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="ui-modal-body text-center">
        <p>Changing the platform that the volume is using may have unintended consequences including loss of data.</p>
        <p>Only proceed if you are sure about the changes you are making.</p>
      </div>
      <div class="ui-modal-footer">
        <button @click="showPlatformWarning = false" type="button" class="ui-button-danger">Dismiss</button>
      </div>
    </div>
  </div>
</div>
{{ end }}
