{{ define "stack-definition-builder" }}
      <!-- Builder Modal -->
      <div x-cloak x-show="editor.active" x-transition.opacity.duration.200ms x-trap.inert.noscroll="editor.active" @keydown.esc.window="if(editor.active && !componentEditor.show && !deleteCompConfirm.show) closeEditor()" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="builderTitle">
        <div x-show="editor.active" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel-2xl max-h-[95vh] flex flex-col">
          <div class="ui-modal-header">
            <div class="ui-modal-icon-info">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" />
              </svg>
            </div>
            <h3 id="builderTitle" class="ui-modal-title" x-text="editor.defId ? 'Edit Stack Definition' : 'Create Stack Definition'"></h3>
            <button @click="closeEditor()" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>

          <!-- Validation errors -->
          <div x-show="editor.errors.length > 0" x-cloak class="px-5 py-2 bg-red-50 dark:bg-red-900/20 border-b border-red-200 dark:border-red-800">
            <template x-for="(err, i) in editor.errors" :key="i">
              <p class="text-xs text-red-700 dark:text-red-400" x-text="err.message"></p>
            </template>
          </div>

          <!-- Main body: metadata + space list -->
          <div class="flex-1 overflow-y-auto">
            <div class="flex flex-col lg:flex-row">
              <!-- Metadata form -->
              <div class="lg:w-2/5 p-5 space-y-4 border-b lg:border-b-0 lg:border-r border-gray-200 dark:border-gray-700">
                <h4 class="text-sm font-semibold text-gray-900 dark:text-white">Definition</h4>
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Name <span class="text-red-500">*</span></label>
                  <input type="text" class="form-field w-full" x-model="editor.form.name" @input="markDirty()" placeholder="My Stack" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
                  <input type="text" class="form-field w-full" x-model="editor.form.description" @input="markDirty()" placeholder="Description of this stack" />
                </div>
                <div>
                  <label class="flex items-center cursor-pointer">
                    <input type="checkbox" class="sr-only peer" :checked="editor.form.active" @change="editor.form.active = !editor.form.active; markDirty()">
                    <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                    <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Active</span>
                  </label>
                </div>
                <!-- Groups as toggles (same pattern as template form) -->
                <div x-show="editor.groups.length" x-cloak>
                  <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Restrict to Groups</label>
                  <template x-for="(group, index) in editor.groups" :key="group.group_id">
                    <label class="flex items-center cursor-pointer mb-2">
                      <input type="checkbox" class="sr-only peer" :checked="editor.form.groups.includes(group.group_id)" @change="toggleGroup(group.group_id)">
                      <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                      <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300" x-text="group.name"></span>
                    </label>
                  </template>
                </div>
                <!-- Zones as dynamic fields (same pattern as template form) -->
                <div>
                  <div class="flex items-center mb-1">
                    <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mr-2">Zones</label>
                    <button type="button" @click="addZone()" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg text-sm p-1">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                      <span class="sr-only">Add Zone</span>
                    </button>
                  </div>
                  <template x-for="(name, index) in editor.form.zones" :key="index">
                    <div class="mb-2">
                      <div class="flex items-center">
                        <input type="text" class="form-field mr-2" x-model="editor.form.zones[index]" @keyup.debounce.500ms="checkZone(index)" :class="{'form-field-error': !editor.zoneValid[index]}" placeholder="Zone Name" :aria-label="'Zone ' + (index + 1)" @input="markDirty()">
                        <button type="button" @click="removeZone(index)" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg text-sm p-1.5">
                          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" /></svg>
                          <span class="sr-only">Remove</span>
                        </button>
                      </div>
                      <div x-show="!editor.zoneValid[index]" class="text-xs text-red-600 dark:text-red-400 mt-0.5">Zone is limited to 64 characters and must appear only once.</div>
                    </div>
                  </template>
                  <p x-show="editor.form.zones.length === 0" class="text-xs text-gray-400 dark:text-gray-500">All zones (add to restrict)</p>
                </div>
              </div>

              <!-- Space list -->
              <div class="lg:w-3/5 p-5">
                <h4 class="text-sm font-semibold text-gray-900 dark:text-white mb-3">Spaces</h4>

                <div x-show="editor.form.spaces.length === 0" class="text-center py-8 text-gray-400 dark:text-gray-500 text-sm">
                  No spaces yet. Click the button below to add one.
                </div>

                <div class="space-y-2">
                  <template x-for="(space, si) in editor.form.spaces" :key="si">
                    <div @click="openComponentEditor(si)" class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700/50 cursor-pointer transition-colors">
                      <div class="flex-1 min-w-0">
                        <div class="text-sm font-medium text-gray-900 dark:text-white truncate" x-text="space.name || 'Unnamed'"></div>
                        <div class="text-xs text-gray-500 dark:text-gray-400 truncate" x-text="space.template_name || 'No template'"></div>
                      </div>
                      <div class="flex items-center gap-1.5 flex-shrink-0">
                        <span x-show="space.depends_on && space.depends_on.length > 0" class="inline-flex items-center gap-0.5 bg-indigo-100 text-indigo-800 text-xs font-medium px-1.5 py-0.5 rounded dark:bg-gray-700 dark:text-indigo-300" x-text="(space.depends_on || []).length + ' dep' + ((space.depends_on || []).length !== 1 ? 's' : '')"></span>
                        <span x-show="space.port_forwards && space.port_forwards.length > 0" class="inline-flex items-center gap-0.5 bg-amber-100 text-amber-800 text-xs font-medium px-1.5 py-0.5 rounded dark:bg-gray-700 dark:text-amber-300" x-text="(space.port_forwards || []).length + ' port' + ((space.port_forwards || []).length !== 1 ? 's' : '')"></span>
                        <span x-show="!space.template_id" class="inline-flex items-center bg-red-100 text-red-700 text-xs font-medium px-1.5 py-0.5 rounded dark:bg-red-900/30 dark:text-red-400">No template</span>
                      </div>
                      <button @click.stop="confirmDeleteComponent(si)" class="text-gray-400 hover:text-red-600 dark:hover:text-red-400 p-1 flex-shrink-0" aria-label="Delete space">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-4"><path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.519.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z" clip-rule="evenodd"/></svg>
                      </button>
                    </div>
                  </template>
                </div>

                <!-- Add button at bottom of list -->
                <button @click="addComponent()" class="mt-3 w-full inline-flex items-center justify-center gap-1 rounded-lg border-2 border-dashed border-gray-300 dark:border-gray-600 px-3 py-2.5 text-sm font-medium text-gray-500 dark:text-gray-400 hover:border-gray-400 dark:hover:border-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" type="button">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-4" aria-hidden="true"><path d="M10.75 4.75a.75.75 0 00-1.5 0v4.5h-4.5a.75.75 0 000 1.5h4.5v4.5a.75.75 0 001.5 0v-4.5h4.5a.75.75 0 000-1.5h-4.5v-4.5z"/></svg>
                  Add Space
                </button>
              </div>
            </div>
          </div>

          <!-- Footer with action buttons -->
          <div class="flex justify-between gap-2 px-5 py-3 border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50">
            <div class="flex gap-2">
              <button @click="exportTOML()" class="btn-secondary" type="button">
                Export TOML
              </button>
              <button @click="exportJSON()" class="btn-secondary" type="button">
                Export JSON
              </button>
            </div>
            <div class="flex gap-2">
              <button @click="closeEditor()" type="button" class="cursor-pointer whitespace-nowrap rounded-lg px-4 py-2 text-center text-sm font-medium tracking-wide text-neutral-600 transition hover:bg-gray-100 dark:text-neutral-300 dark:hover:bg-gray-700">Cancel</button>
              <button @click="saveDefinition()" :disabled="editor.saving || !editor.valid" class="btn-primary" type="button">
                <span x-text="editor.saving ? 'Saving...' : 'Save'"></span>
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Delete Space Confirmation Modal -->
      <div x-cloak x-show="deleteCompConfirm.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="deleteCompConfirm.show" @keydown.esc.window="deleteCompConfirm.show = false" @click.self="deleteCompConfirm.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="deleteCompTitle">
        <div x-show="deleteCompConfirm.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel">
          <div class="ui-modal-header">
            <div class="ui-modal-icon-danger">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
              </svg>
            </div>
            <h3 id="deleteCompTitle" class="ui-modal-title">Confirm Delete</h3>
            <button @click="deleteCompConfirm.show = false" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="ui-modal-body text-center">
            <p>Are you sure you want to delete the space <strong x-text="editor.form.spaces[deleteCompConfirm.index]?.name || ''"></strong>?</p>
          </div>
          <div class="ui-modal-footer">
            <button @click="deleteCompConfirm.show = false" type="button" class="ui-button-secondary">Keep Space</button>
            <button @click="executeDeleteComponent()" type="button" class="ui-button-danger">Delete Space</button>
          </div>
        </div>
      </div>

      <!-- Discard Unsaved Changes Confirmation -->
      <div x-cloak x-show="discardConfirm.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="discardConfirm.show" @keydown.esc.window="discardConfirm.show = false" @click.self="discardConfirm.show = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="discardTitle">
        <div x-show="discardConfirm.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel">
          <div class="ui-modal-header">
            <div class="ui-modal-icon-danger">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z" />
              </svg>
            </div>
            <h3 id="discardTitle" class="ui-modal-title">Unsaved Changes</h3>
            <button @click="discardConfirm.show = false" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
          <div class="ui-modal-body text-center">
            <p>You have unsaved changes. Are you sure you want to discard them?</p>
          </div>
          <div class="ui-modal-footer">
            <button @click="discardConfirm.show = false" type="button" class="ui-button-secondary">Keep Editing</button>
            <button @click="discardChanges()" type="button" class="ui-button-danger">Discard Changes</button>
          </div>
        </div>
      </div>

      <!-- Space Edit Modal -->
      <div x-cloak x-show="componentEditor.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="componentEditor.show" @keydown.esc.window="if(componentEditor.show) cancelComponentEditor()" @click.self="cancelComponentEditor()" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="compEditorTitle">
        <div x-show="componentEditor.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel-wide max-h-[90vh] flex flex-col">
          <div class="ui-modal-header">
            <div class="ui-modal-icon-info">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
              </svg>
            </div>
            <h3 id="compEditorTitle" class="ui-modal-title">Edit Space</h3>
            <button @click="cancelComponentEditor()" aria-label="close modal" class="ui-modal-close">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>

          <div class="flex-1 overflow-y-auto">
            <div class="ui-modal-body space-y-4">
              <!-- Name -->
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Name <span class="text-red-500">*</span></label>
                <input type="text" class="form-field w-full" x-model="componentEditor.form.name" @input="markDirty()" placeholder="e.g. db" />
              </div>

              <!-- Template -->
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Template</label>
                <div x-data="autocompleterTemplatePicker()" @sync-comp-pickers.window="syncSearch()" class="relative">
                  <input type="search" class="form-field w-full text-sm" placeholder="Search templates..." x-model="search" @focus="handleFocus" @click="handleFocus" @keydown="handleKeydown" @input="handleInput()" @blur="setTimeout(() => showList = false, 200)" aria-autocomplete="list" :aria-controls="'tmpl-listbox-' + _listboxId" :aria-activedescendant="activeDescendant" />
                  <ul x-show="showList && filteredTemplates.length > 0" :id="'tmpl-listbox-' + _listboxId" role="listbox" class="absolute z-50 w-full mt-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded-lg shadow-lg max-h-40 overflow-auto">
                    <template x-for="(t, ti) in filteredTemplates" :key="t.template_id">
                      <li :id="_listboxId + '-opt-' + ti" role="option" :aria-selected="selectedIndex === ti" @mousedown.prevent="selectTemplate(t)" :class="selectedIndex === ti ? 'bg-blue-50 dark:bg-blue-900/30' : ''" class="px-3 py-2 text-sm cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700">
                        <span x-text="t.name" class="font-medium"></span>
                        <span x-show="t.platform" class="text-gray-400 ml-1" x-text="'(' + t.platform + ')'"></span>
                      </li>
                    </template>
                  </ul>
                </div>
              </div>

              <!-- Description -->
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
                <input type="text" class="form-field w-full" x-model="componentEditor.form.description" @input="markDirty()" placeholder="Space description" />
              </div>

              <!-- Shell -->
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Shell</label>
                <select class="form-field w-full" x-model="componentEditor.form.shell" @change="markDirty()">
                  <option value="">Default</option>
                  <option value="bash">Bash</option>
                  <option value="zsh">Zsh</option>
                  <option value="fish">Fish</option>
                  <option value="sh">Sh</option>
                </select>
              </div>

              <!-- Startup Script -->
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Startup Script</label>
                <div x-data="autocompleterScriptPicker()" @sync-comp-pickers.window="syncSearch()" class="relative">
                  <input type="search" class="form-field w-full text-sm" placeholder="Search scripts..." x-model="search" @focus="handleFocus" @click="handleFocus" @keydown="handleKeydown" @input="handleInput()" @blur="setTimeout(() => showList = false, 200)" aria-autocomplete="list" :aria-controls="'script-listbox-' + _listboxId" :aria-activedescendant="activeDescendant" />
                  <ul x-show="showList && filteredScripts.length > 0" :id="'script-listbox-' + _listboxId" role="listbox" class="absolute z-50 w-full mt-1 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-600 rounded-lg shadow-lg max-h-40 overflow-auto">
                    <template x-for="(s, si) in filteredScripts" :key="s.script_id">
                      <li :id="_listboxId + '-opt-' + si" role="option" :aria-selected="selectedIndex === si" @mousedown.prevent="selectScript(s)" :class="selectedIndex === si ? 'bg-blue-50 dark:bg-blue-900/30' : ''" class="px-3 py-2 text-sm cursor-pointer hover:bg-gray-100 dark:hover:bg-gray-700" x-text="s.name"></li>
                    </template>
                  </ul>
                </div>
              </div>

              <!-- Depends On (checkbox toggles for other spaces) -->
              <div x-show="componentEditor.form._targetOptions && componentEditor.form._targetOptions.length > 0">
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Depends On</label>
                <template x-for="otherName in componentEditor.form._targetOptions" :key="otherName">
                  <label class="flex items-center cursor-pointer mb-2">
                    <input type="checkbox" class="sr-only peer" :checked="componentEditor.form.depends_on.includes(otherName)" @change="toggleDependency(otherName)">
                    <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                    <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300" x-text="otherName"></span>
                  </label>
                </template>
              </div>

              <!-- Custom Fields (driven by template) -->
              <fieldset x-show="componentEditor.form.custom_fields.length > 0" class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
                <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Custom Fields</legend>
                <div class="space-y-4">
                  <template x-for="(cf, cfi) in componentEditor.form.custom_fields" :key="cfi">
                    <div>
                      <label class="form-label" x-text="cf.description ? cf.description + ' (' + cf.name + ')' : cf.name"></label>
                      <input type="text" class="form-field" placeholder="Field value" x-model="cf.value" @input="markDirty()" :aria-label="cf.description ? cf.description + ' value' : cf.name + ' value'">
                    </div>
                  </template>
                </div>
              </fieldset>

              <!-- Port Forwards -->
              <div>
                <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Port Forwards</label>
                <template x-for="(pf, pfi) in componentEditor.form.port_forwards" :key="pfi">
                  <div class="flex gap-2 mb-2 items-center" x-init="initPfRow($el, pf)">
                    <select class="form-field w-28 text-sm" x-model="pf.to_space" @change="markDirty()">
                      <option value="">Target</option>
                    </select>
                    <input type="number" class="form-field w-28 text-sm" placeholder="Local" x-model.number="pf.local_port" @input="markDirty()" min="1" max="65535" />
                    <span class="text-xs text-gray-500">&rarr;</span>
                    <input type="number" class="form-field w-28 text-sm" placeholder="Remote" x-model.number="pf.remote_port" @input="markDirty()" min="1" max="65535" />
                    <button @click="removePortForwardFromEditor(pfi)" class="text-gray-400 hover:text-red-600 dark:hover:text-red-400 p-1 flex-shrink-0" aria-label="Remove port forward">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-4"><path fill-rule="evenodd" d="M8.75 1A2.75 2.75 0 006 3.75v.443c-.795.077-1.584.176-2.365.298a.75.75 0 10.23 1.482l.149-.022.841 10.518A2.75 2.75 0 007.596 19h4.807a2.75 2.75 0 002.742-2.53l.841-10.519.149.023a.75.75 0 00.23-1.482A41.03 41.03 0 0014 4.193V3.75A2.75 2.75 0 0011.25 1h-2.5zM10 4c.84 0 1.673.025 2.5.075V3.75c0-.69-.56-1.25-1.25-1.25h-2.5c-.69 0-1.25.56-1.25 1.25v.325C8.327 4.025 9.16 4 10 4zM8.58 7.72a.75.75 0 00-1.5.06l.3 7.5a.75.75 0 101.5-.06l-.3-7.5zm4.34.06a.75.75 0 10-1.5-.06l-.3 7.5a.75.75 0 101.5.06l.3-7.5z" clip-rule="evenodd"/></svg>
                    </button>
                  </div>
                </template>
                <button @click="addPortForwardToEditor()" class="text-xs text-blue-600 dark:text-blue-400 hover:underline">+ Add Port Forward</button>
              </div>
            </div>
          </div>

          <div class="ui-modal-footer">
            <button @click="cancelComponentEditor()" type="button" class="ui-button-secondary">Cancel</button>
            <button @click="saveComponentEditor()" type="button" class="ui-button-primary">Save</button>
          </div>
        </div>
      </div>
{{ end }}
