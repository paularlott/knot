{{ define "template-form-content" }}
<div x-data="templateForm(templateFormModal.isEdit, templateFormModal.templateId, templateFormModal.isDuplicate || false)" x-init="initData">
      {{ template "loading" . }}
      <form class="space-y-6" action="" method="POST" @submit.prevent="submitData" x-show="!loading" x-cloak>
        <fieldset class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">General</legend>
          <div class="space-y-6">
            <div>
              <label for="name" class="form-label">Name</label>
              <input type="text" class="form-field" name="name" id="name" x-on:keyup.debounce.500ms="checkName()" :class="{'form-field-error': !nameValid}" placeholder="Template name" x-model="formData.name">
              <div x-show="!nameValid" class="error-message" x-cloak>Template name can be a max 64 characters.</div>
            </div>
            <div>
              <label class="form-label">Description</label>
              <div class="short-editor">
                <div class="editor-wrap">
                  <textarea name="description" class="form-field" id="description" placeholder="Description"></textarea>
                </div>
              </div>
            </div>
            <div x-data="autocompleterIcon(iconList)" data-parent-var-group="formData" data-parent-variable="icon_url" @refresh-autocompleter.window="refresh()" x-id="['dropdown']">
              <label for="icon_url" class="form-label">Template Icon</label>
              <div class="flex items-center">
                <img x-show="formData.icon_url.length" :src="formData.icon_url" alt="Icon" class="size-10 mr-2">
                <div class="relative w-full max-w-sm">
                  <input id="icon_url" x-model="search" class="form-field" type="search" placeholder="Search icons..." role="combobox" :aria-expanded="showList && filteredOptions.length > 0" :aria-activedescendant="activeDescendant" :aria-controls="_listboxId" @focus="handleFocus()" @blur.debounce.200ms="showList = false" @keydown="handleKeydown($event)" x-ref="searchInput" spellcheck="false" autocomplete="off">
                  <div x-show="showList && filteredOptions.length" x-ref="dropdown" :style="dropdownStyle" x-cloak :class="{'hidden': !dropdownVisible}" class="fixed z-[70] max-h-40 overflow-auto text-base p-2 list-none bg-white divide-y divide-gray-100 rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 whitespace-nowrap">
                    <ul class="list-none" role="listbox" :id="_listboxId">
                      <template x-for="(option, index) in filteredOptions" :key="index">
                        <li @click="selectOption(option)" :id="`${_listboxId}-opt-${index}`" role="option" :aria-selected="selectedIndex === index" :class="{'bg-blue-100 dark:bg-blue-900': selectedIndex === index}" class="my-1 cursor-pointer nav-item text-sm">
                          <img x-show="option.url.length" :src="option.url" alt="Icon" class="size-10 mr-2">
                          <div x-text="option.description + ' (' + option.source + ')'"></div>
                        </li>
                      </template>
                    </ul>
                  </div>
                </div>
              </div>
            </div>
            <div class="mb-4">
              <label class="block mb-2 text-sm font-medium text-gray-900 dark:text-white">Platform</label>
              <div class="flex items-center space-x-2 p-2 bg-gray-100 dark:bg-gray-700 rounded-lg w-fit">
                <template x-for="platform in ['Manual', 'Nomad']" :key="platform">
                  <label class="relative">
                    <input
                      type="radio"
                      name="platform"
                      :value="platform.toLowerCase()"
                      x-model="formData.platform"
                      class="sr-only peer"
                      {{ if .isEdit }}@change="showPlatformWarning = true"{{ end }}
                    >
                    <div class="select-none cursor-pointer px-2 sm:px-4 py-2 rounded-lg text-sm font-medium
                      peer-checked:bg-blue-600 peer-checked:text-white
                      peer-focus:ring-2 peer-focus:ring-blue-300
                      transition-colors duration-200 ease-in-out
                      text-gray-700 dark:text-gray-200 peer-checked:dark:text-white
                      hover:bg-gray-200 hover:text-gray-700 hover:peer-checked:bg-blue-600 hover:peer-checked:text-white hover:dark:bg-gray-600 hover:dark:text-white hover:dark:peer-checked:bg-blue-600">
                    <span x-text="platform"></span>
                  </div>
                  </label>
                </template>

                <!-- Local Container split button -->
                <div class="relative inline-flex" x-data="{ open: false, isLocalContainer() { return ['docker', 'podman', 'apple', 'container'].includes(formData.platform); } }">
                  <label class="relative group">
                    <input
                      type="radio"
                      name="platform"
                      :value="isLocalContainer() ? formData.platform : 'container'"
                      :checked="isLocalContainer()"
                      @change="if (!isLocalContainer()) formData.platform = 'container'; {{ if .isEdit }}showPlatformWarning = true{{ end }}"
                      class="sr-only peer"
                    >
                    <div class="select-none cursor-pointer px-2 sm:px-4 py-2 rounded-l-lg text-sm font-medium transition-colors duration-200 ease-in-out"
                      :class="isLocalContainer() ? 'bg-blue-600 text-white peer-focus:ring-2 peer-focus:ring-blue-300 group-hover:bg-blue-500' : 'text-gray-700 dark:text-gray-200 group-hover:bg-gray-200 group-hover:dark:bg-gray-600'">
                      <span x-text="formData.platform === 'docker' ? 'Docker' : formData.platform === 'podman' ? 'Podman' : formData.platform === 'apple' ? 'Apple' : 'Local Container'"></span>
                    </div>
                  </label>
                  <button
                    type="button"
                    @click="open = !open"
                    @click.away="open = false"
                    aria-label="Select container platform"
                    class="px-2 py-2 rounded-r-lg text-sm font-medium border-l transition-colors duration-200 ease-in-out"
                    :class="isLocalContainer() ? 'bg-blue-600 text-white border-blue-700 dark:border-blue-500 hover:bg-blue-500' : 'bg-transparent text-gray-700 dark:text-gray-200 border-gray-300 dark:border-gray-600 hover:bg-gray-200 hover:dark:bg-gray-600'"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                  </button>
                  <div
                    x-show="open"
                    x-cloak
                    class="absolute top-full mt-1 right-0 z-50 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-xl min-w-[160px]"
                  >
                    <div class="p-1">
                      <button
                        type="button"
                        @click="formData.platform = 'container'; open = false; {{ if .isEdit }}showPlatformWarning = true{{ end }}"
                        class="w-full text-left px-3 py-2 text-sm rounded hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200"
                      >
                        Local Container
                      </button>
                      <button
                        type="button"
                        @click="formData.platform = 'docker'; open = false; {{ if .isEdit }}showPlatformWarning = true{{ end }}"
                        class="w-full text-left px-3 py-2 text-sm rounded hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200"
                      >
                        Docker
                      </button>
                      <button
                        type="button"
                        @click="formData.platform = 'podman'; open = false; {{ if .isEdit }}showPlatformWarning = true{{ end }}"
                        class="w-full text-left px-3 py-2 text-sm rounded hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200"
                      >
                        Podman
                      </button>
                      <button
                        type="button"
                        @click="formData.platform = 'apple'; open = false; {{ if .isEdit }}showPlatformWarning = true{{ end }}"
                        class="w-full text-left px-3 py-2 text-sm rounded hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-700 dark:text-gray-200"
                      >
                        Apple
                      </button>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div x-show="formData.platform != 'manual'" x-cloak>
              <label class="flex items-center cursor-pointer mb-2">
                <input type="checkbox" class="sr-only peer" value="1" :checked="formData.active" x-model="formData.active">
                <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Active</span>
              </label>
            </div>
          </div>
        </fieldset>

        <fieldset x-show="formData.platform != 'manual'" x-cloak class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Orchestration</legend>
          <div class="space-y-6">
            <div>
              <label class="form-label"><span x-show="!isLocalContainer()">Nomad Job (HCL)</span><span x-show="isLocalContainer()">Container Specification (YAML)</span></label>
              <div class="large-editor">
                <div :class="{'form-field-error': !jobValid, 'editor-wrap': true}">
                  <textarea name="job" class="form-field" id="job"></textarea>
                </div>
                <div x-show="jobRequired" class="error-message" x-cloak>Template is required.</div>
                <template x-if="specErrors.job.length">
                  <div class="mt-2 space-y-1">
                    <template x-for="(error, index) in specErrors.job" :key="`job-${index}`">
                      <div class="error-message" x-text="error"></div>
                    </template>
                  </div>
                </template>
              </div>
            </div>
            <div>
              <label class="form-label">Volume Definition (YAML)</label>
              <div class="mid-editor">
                <div :class="{'form-field-error': !volValid, 'editor-wrap': true}">
                  <textarea name="vol" class="form-field" id="vol"></textarea>
                </div>
                <div x-show="volRequired" class="error-message" x-cloak>Volume definition is required.</div>
                <template x-if="specErrors.volumes.length">
                  <div class="mt-2 space-y-1">
                    <template x-for="(error, index) in specErrors.volumes" :key="`volume-${index}`">
                      <div class="error-message" x-text="error"></div>
                    </template>
                  </div>
                </template>
              </div>
            </div>
            {{ if not .isLeafNode }}
            <div>
              <label class="form-label">Scripts</label>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div x-data="autocompleterScript()" data-parent-var-group="formData" data-parent-variable="startup_script_id" @refresh-autocompleter.window="refresh()" x-id="['dropdown']">
                  <label for="startup_script_id" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">System Startup Script</label>
                  <div class="relative w-full">
                    <input id="startup_script_id" x-model="search" class="form-field" type="search" placeholder="Search scripts..." role="combobox" :aria-expanded="showList && filteredOptions.length > 0" :aria-activedescendant="activeDescendant" :aria-controls="_listboxId" @focus="handleFocus()" @blur.debounce.200ms="showList = false" @keydown="handleKeydown($event)" x-ref="searchInput" spellcheck="false" autocomplete="off">
                    <div x-show="showList && filteredOptions.length" x-ref="dropdown" :style="dropdownStyle" x-cloak :class="{'hidden': !dropdownVisible}" class="fixed z-[70] max-h-40 overflow-auto text-base p-2 list-none bg-white divide-y divide-gray-100 rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 whitespace-nowrap">
                      <ul class="list-none" role="listbox" :id="_listboxId">
                        <template x-for="(option, index) in filteredOptions" :key="index">
                          <li @click="selectOption(option)" :id="`${_listboxId}-opt-${index}`" role="option" :aria-selected="selectedIndex === index" :class="{'bg-blue-100 dark:bg-blue-900': selectedIndex === index}" class="my-1 cursor-pointer nav-item text-sm px-2 py-1">
                            <div x-text="option.name"></div>
                          </li>
                        </template>
                      </ul>
                    </div>
                  </div>
                </div>
                <div x-data="autocompleterScript()" data-parent-var-group="formData" data-parent-variable="shutdown_script_id" @refresh-autocompleter.window="refresh()" x-id="['dropdown']">
                  <label for="shutdown_script_id" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">System Shutdown Script</label>
                  <div class="relative w-full">
                    <input id="shutdown_script_id" x-model="search" class="form-field" type="search" placeholder="Search scripts..." role="combobox" :aria-expanded="showList && filteredOptions.length > 0" :aria-activedescendant="activeDescendant" :aria-controls="_listboxId" @focus="handleFocus()" @blur.debounce.200ms="showList = false" @keydown="handleKeydown($event)" x-ref="searchInput" spellcheck="false" autocomplete="off">
                    <div x-show="showList && filteredOptions.length" x-ref="dropdown" :style="dropdownStyle" x-cloak :class="{'hidden': !dropdownVisible}" class="fixed z-[70] max-h-40 overflow-auto text-base p-2 list-none bg-white divide-y divide-gray-100 rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 whitespace-nowrap">
                      <ul class="list-none" role="listbox" :id="_listboxId">
                        <template x-for="(option, index) in filteredOptions" :key="index">
                          <li @click="selectOption(option)" :id="`${_listboxId}-opt-${index}`" role="option" :aria-selected="selectedIndex === index" :class="{'bg-blue-100 dark:bg-blue-900': selectedIndex === index}" class="my-1 cursor-pointer nav-item text-sm px-2 py-1">
                            <div x-text="option.name"></div>
                          </li>
                        </template>
                      </ul>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            {{ end }}
          </div>
        </fieldset>

        <fieldset x-show="formData.platform != 'manual'" x-cloak class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Resources</legend>
          <div class="space-y-6">
            {{ if not .isLeafNode }}
            <div>
              <label class="form-label">Resource Units</label>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                  <label for="compute_units" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Compute Units</label>
                  <input type="number" class="form-field" name="compute_units" id="compute_units" x-model="formData.compute_units" min="0" x-on:keyup.debounce.500ms="checkComputeUnits()" :class="{'form-field-error': !computeUnitsValid}" >
                  <div x-show="!computeUnitsValid" class="error-message" x-cloak>Enter a valid number >= 0</div>
                </div>
                <div>
                  <label for="storage_units" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Storage Units</label>
                  <input type="number" class="form-field" name="storage_units" id="storage_units" x-model="formData.storage_units" min="0" x-on:keyup.debounce.500ms="checkStorageUnits()" :class="{'form-field-error': !storageUnitsValid}" >
                  <div x-show="!storageUnitsValid" class="error-message" x-cloak>Enter a valid number >= 0</div>
                </div>
              </div>
              <p class="description">Compute units count when a space is running. Storage units count once a space is created.</p>
            </div>
            {{ end }}
            <div>
              <label for="uptime_unit" class="form-label">Maximum Uptime</label>
              <div class="flex grid-cols-2 gap-2">
                <input x-cloak x-show="formData.max_uptime_unit != 'disabled'" type="number" class="form-field w-full max-w-1/4" name="uptime" id="uptime" x-model="formData.max_uptime" min="0" x-on:keyup.debounce.500ms="checkUptime()" :class="{'form-field-error': !uptimeValid}" aria-label="Maximum uptime value">
                <select class="form-field pr-10 w-auto" name="uptime_unit" id="uptime_unit" x-model="formData.max_uptime_unit" x-on:change="checkUptime()" :class="{'form-field-error': !uptimeValid}">
                  <option value="disabled">No Limit</option>
                  <option value="minute">Minutes</option>
                  <option value="hour">Hours</option>
                  <option value="day">Days</option>
                </select>
              </div>
              <p class="description">The maximum amount of time a space created from the template can run for.</p>
              <div x-show="!uptimeValid" class="error-message" x-cloak>Enter a valid number >= 0</div>
            </div>
          </div>
        </fieldset>

        <fieldset x-show="formData.platform != 'manual'" x-cloak class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Schedule</legend>
          <div class="space-y-6">
            <div>
              <label class="flex items-center cursor-pointer mb-2">
                <input type="checkbox" class="sr-only peer" value="1" :checked="formData.schedule_enabled" x-model="formData.schedule_enabled">
                <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Schedule</span>
              </label>
            </div>
            <div x-show="formData.schedule_enabled" x-cloak>
              <div class="mb-4">
                <label class="flex items-center cursor-pointer mb-2">
                  <input type="checkbox" class="sr-only peer" value="1" :checked="formData.auto_start" x-model="formData.auto_start">
                  <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                  <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Auto Start</span>
                </label>
              </div>

              <template x-for="index in 7" :key="index">
                <div class="grid grid-cols-2 sm:grid-cols-3 gap-x-2 sm:gap-4 w-full max-w-xl">
                  <div class="col-span-2 sm:col-span-1 mb-0 sm:mb-2">
                    <label class="flex items-center cursor-pointer py-2.5">
                      <input type="checkbox" class="sr-only peer" value="1" :checked="formData.schedule[index % 7].enabled" @change="toggleDaySchedule(index % 7)">
                      <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                      <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300" x-text="getDayOfWeek(index % 7)"></span>
                    </label>
                  </div>
                  <div class="col-span-1">
                    <label :for="'schedule-from-' + (index % 7)" class="sr-only" x-text="'From time for ' + formData.schedule[index % 7].day"></label>
                    <select class="form-field" :class="{'opacity-40 hidden sm:block': !formData.schedule[index % 7].enabled}" :id="'schedule-from-' + (index % 7)" x-model="formData.schedule[index % 7].from">
                      <template x-for="hour in fromHours" :key="hour">
                        <option x-text="hour" :value="hour" x-bind:selected="hour == formData.schedule[index % 7].from"></option>
                      </template>
                    </select>
                  </div>
                  <div class="col-span-1">
                    <label :for="'schedule-to-' + (index % 7)" class="sr-only" x-text="'To time for ' + formData.schedule[index % 7].day"></label>
                    <select class="form-field" :class="{'opacity-40 hidden sm:block': !formData.schedule[index % 7].enabled}" :id="'schedule-to-' + (index % 7)" x-model="formData.schedule[index % 7].to">
                      <template x-for="hour in toHours" :key="hour">
                        <option x-text="hour" :value="hour" x-bind:selected="hour == formData.schedule[index % 7].to"></option>
                      </template>
                    </select>
                  </div>
                </div>
              </template>
              <div class="description text-right max-w-xl">All times are in {{ .timezone }}.</div>
            </div>
          </div>
        </fieldset>

        <fieldset class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Features & Access</legend>
          <div class="space-y-6">
            <div class="grid grid-cols-1 lg:grid-cols-2 xl:gap-4">
              <div class="col-span-1">
                <label class="form-label">Features</label>
                <label class="flex items-center cursor-pointer mb-2">
                  <input type="checkbox" class="sr-only peer" value="1" :checked="formData.with_terminal" x-model="formData.with_terminal">
                  <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                  <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Web Terminal</span>
                </label>
                <label class="flex items-center cursor-pointer mb-2">
                  <input type="checkbox" class="sr-only peer" value="1" :checked="formData.with_ssh" x-model="formData.with_ssh">
                  <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                  <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">SSH</span>
                </label>
                <label class="flex items-center cursor-pointer mb-2">
                  <input type="checkbox" class="sr-only peer" value="1" :checked="formData.with_code_server" x-model="formData.with_code_server">
                  <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                  <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Code Server</span>
                </label>
                <label class="flex items-center cursor-pointer mb-2">
                  <input type="checkbox" class="sr-only peer" value="1" :checked="formData.with_vscode_tunnel" x-model="formData.with_vscode_tunnel">
                  <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                  <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">VSCode Tunnel</span>
                </label>
                <label class="flex items-center cursor-pointer mb-2">
                  <input type="checkbox" class="sr-only peer" value="1" :checked="formData.with_run_command" x-model="formData.with_run_command">
                  <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                  <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Run Commands / Copy Files</span>
                </label>
              </div>
              {{ if not .isLeafNode }}
              <div class="col-span-1 mt-4 lg:mt-0" x-show="groups.length" x-cloak>
                <label class="form-label">Restrict to Groups</label>
                <template x-for="(group, index) in groups" :key="index">
                  <label class="flex items-center cursor-pointer mb-2">
                    <input type="checkbox" class="sr-only peer" :id="'group-' + index" name="groups[]" :value="group.group_id" :checked="formData.groups.includes(group.group_id)" @change="toggleGroup(group.group_id)">
                    <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                    <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300" x-text="group.name"></span>
                  </label>
                </template>
              </div>
              {{ end }}
            </div>
            {{ if not .isLeafNode }}
            <div class="max-w-md">
              <div class="flex items-center mb-1">
                <label class="form-label mb-0 mr-2">Limit to Zones</label>
                <button type="button" x-on:click="addZone()" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg text-sm p-2.5">
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true" >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                  </svg>
                  <span class="sr-only">Add</span>
                </button>
              </div>
              <template x-for="(name, index) in formData.zones" :key="index">
                <div class="mb-2">
                  <div class="flex items-center">
                    <input type="text" class="form-field mr-2" x-model="formData.zones[index]" x-on:keyup.debounce.500ms="checkZone(index)" :class="{'form-field-error': !zoneValid[index]}" placeholder="Zone Name" aria-label="Zone Name">
                    <button type="button" x-on:click="removeZone(index)" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg text-sm p-2.5">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true" >
                        <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                      </svg> <span class="sr-only">Remove</span>
                    </button>
                  </div>
                  <div x-show="!zoneValid[index]" class="error-message">Zone is limited to 64 characters and must appear only once.</div>
                </div>
              </template>
              <div class="description">Restrict the zones the template shows within.<br />Prefix the zone name with ! to exclude the zone.</div>
            </div>
            {{ end }}
          </div>
        </fieldset>

        <fieldset x-show="formData.platform != 'manual'" x-cloak class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Custom Fields</legend>
          <div class="space-y-6">
            <div class="flex items-center justify-between gap-4 mb-3">
              <div class="description">Additional fields shown when creating a space from this template.</div>
              <button type="button" x-on:click="addField()" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg text-sm p-2.5 shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true" >
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
                <span class="sr-only">Add</span>
              </button>
            </div>
            <template x-for="(field, index) in formData.custom_fields" :key="index">
              <div class="mb-2">
                <div class="flex items-center">
                  <input type="text" class="form-field mr-2 max-w-xs" x-model="formData.custom_fields[index].name" x-on:keyup.debounce.500ms="checkCustomField(index)" :class="{'form-field-error': !customFieldValid[index]}" placeholder="Variable Name" aria-label="Variable Name">
                  <input type="text" class="form-field mr-2" x-model="formData.custom_fields[index].description" x-on:keyup.debounce.500ms="checkCustomField(index)" :class="{'form-field-error': !customFieldValid[index]}" placeholder="Field Label / Description" aria-label="Field Label / Description">
                  <button type="button" x-on:click="removeField(index)" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg text-sm p-2.5">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true" >
                      <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                    </svg> <span class="sr-only">Remove</span>
                  </button>
                </div>
                <div x-show="!customFieldValid[index]" class="error-message">The field name is limited to 64 characters and must start with a letter and only contain a - z, A - Z, 0 - 9 and _. The description is optional and must be less than 256 characters.</div>
              </div>
            </template>
          </div>
        </fieldset>

        <fieldset x-show="formData.platform != 'manual'" x-cloak class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Health Check</legend>
          <div class="flex items-center space-x-2 p-2 bg-gray-100 dark:bg-gray-700 rounded-lg w-fit mb-3">
            <template x-for="hcType in ['None', 'TCP', 'HTTP', 'Program', 'Custom']" :key="hcType">
              <label class="relative">
                <input
                  type="radio"
                  name="health_check_type"
                  :value="hcType.toLowerCase()"
                  x-model="formData.health_check_type"
                  @change="formData.health_check_config = ''; formData.health_check_skip_ssl_verify = false"
                  class="sr-only peer"
                >
                <div class="select-none cursor-pointer px-2 sm:px-4 py-2 rounded-lg text-sm font-medium
                  peer-checked:bg-blue-600 peer-checked:text-white
                  peer-focus:ring-2 peer-focus:ring-blue-300
                  transition-colors duration-200 ease-in-out
                  text-gray-700 dark:text-gray-200 peer-checked:dark:text-white
                  hover:bg-gray-200 hover:text-gray-700 hover:peer-checked:bg-blue-600 hover:peer-checked:text-white hover:dark:bg-gray-600 hover:dark:text-white hover:dark:peer-checked:bg-blue-600"
                  x-text="hcType"></div>
              </label>
            </template>
          </div>

          <div x-show="formData.health_check_type === 'tcp'" x-cloak>
            <label class="form-label">Port Number</label>
            <input type="number" class="form-field" x-model="formData.health_check_config" min="1" max="65535" placeholder="e.g. 5432">
          </div>

          <div x-show="formData.health_check_type === 'http'" x-cloak>
            <label class="form-label">URL</label>
            <input type="text" class="form-field" x-model="formData.health_check_config" placeholder="e.g. http://localhost:8080/health">
            <label class="flex items-center cursor-pointer mt-2">
              <input type="checkbox" class="sr-only peer" x-model="formData.health_check_skip_ssl_verify">
              <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
              <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Skip SSL Verify</span>
            </label>
          </div>

          <div x-show="formData.health_check_type === 'program'" x-cloak>
            <label class="form-label">Command</label>
            <input type="text" class="form-field" x-model="formData.health_check_config" placeholder="e.g. pg_isready">
          </div>

          <div x-show="formData.health_check_type === 'custom'" x-cloak>
            <label class="form-label">Script</label>
            <div class="mid-editor">
              <div class="editor-wrap">
                <textarea id="health_check_script" x-ref="healthCheckScriptEl"></textarea>
              </div>
            </div>
          </div>

          <div x-show="formData.health_check_type !== 'none'" x-cloak class="mt-3 grid grid-cols-3 gap-3">
            <div x-show="formData.health_check_type !== 'custom'">
              <label class="form-label">Timeout (seconds)</label>
              <input type="number" class="form-field" x-model="formData.health_check_timeout" min="1" placeholder="10">
            </div>
            <div>
              <label class="form-label">Check Interval (seconds)</label>
              <input type="number" class="form-field" x-model="formData.health_check_interval" min="5" placeholder="30">
            </div>
            <div>
              <label class="form-label">Max Failures</label>
              <input type="number" class="form-field" x-model="formData.health_check_max_failures" min="1" placeholder="3">
            </div>
          </div>

          <div x-show="formData.health_check_type !== 'none'" x-cloak class="mt-2">
            <label class="flex items-center cursor-pointer">
              <input type="checkbox" class="sr-only peer" x-model="formData.health_check_auto_restart">
              <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
              <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Auto-restart on failure</span>
            </label>
          </div>
        </fieldset>

        <div class="flex justify-between gap-2 pt-4 border-t border-neutral-300 dark:border-gray-700">
          <button type="button" @click="templateFormModal.show = false" class="cursor-pointer whitespace-nowrap rounded-lg px-4 py-2 text-center text-sm font-medium tracking-wide text-neutral-600 transition hover:bg-gray-100 dark:text-neutral-300 dark:hover:bg-gray-700" x-text="isEdit ? 'Discard' : 'Cancel'"></button>
          <div class="flex gap-2">
            <button type="button" @click="submitData(true)" class="btn-secondary" :disabled="loading || formData.is_managed">Save & Edit</button>
            <button type="button" @click="submitData(false)" class="btn-primary"  :disabled="loading || formData.is_managed" x-text="isEdit ? 'Save' : 'Create'"></button>
          </div>
        </div>

      </form>
</div>
{{ end }}
