{{ define "space-form-content" }}
<div x-data="spaceForm(spaceFormModal.isEdit, spaceFormModal.spaceId, '{{ .user_id }}', '{{ .preferredShell }}', spaceFormModal.forUserId, spaceFormModal.forUserUsername, spaceFormModal.templateId)" x-init="initData">
  {{ template "loading" . }}
  <form class="space-y-6" x-show="!loading" x-cloak @submit.prevent="submitData">
    <div>
      <label for="name" class="form-label">Space Name</label>
      <input type="text" class="form-field" name="name" id="name" x-on:keyup.debounce.500ms="checkName()" :class="{'form-field-error': !nameValid}" placeholder="Space name" x-model="formData.name">
      <div x-show="!nameValid" class="error-message" x-cloak>Space names can only contain the letters a - Z, 0 - 9 and -, max 64 characters.</div>
    </div>
    <div>
      <label class="form-label">Description</label>
      <div class="short-editor">
        <div :class="{'form-field-error': !descValid, 'editor-wrap': true}">
          <textarea name="description" id="description" class="form-field" placeholder="Description"></textarea>
        </div>
      </div>
      <div x-show="!descValid" class="error-message" x-cloak>Description must be less than 64K characters.</div>
    </div>
    <div x-show="!spaceFormModal.isEdit && availableNodes.length > 1" x-cloak>
      <label for="node" class="form-label">Node</label>
      <select class="form-field" name="node" id="node" x-model="formData.selected_node_id">
        <option value="">Auto-select</option>
        <template x-for="node in availableNodes" :key="node.node_id">
          <option :value="node.node_id" x-text="formatNodeLabel(node)"></option>
        </template>
      </select>
      <div class="description">The node where this space will run. Auto-select chooses the node with the least load.</div>
    </div>
    <div x-data="autocompleterIcon(iconList)" data-parent-var-group="formData" data-parent-variable="icon_url" @refresh-autocompleter.window="refresh()" x-id="['dropdown']">
      <label for="icon_url" class="form-label">Icon</label>
      <div class="flex items-center">
        <img x-show="formData.icon_url.length" :src="formData.icon_url" alt="Icon" class="size-10 mr-2">
        <div class="relative w-full max-w-sm">
          <input id="icon_url" x-model="search" class="form-field" type="search" placeholder="Search icons..." role="combobox" :aria-expanded="showList && filteredOptions.length > 0" :aria-activedescendant="activeDescendant" :aria-controls="_listboxId" @focus="handleFocus()" @blur.debounce.200ms="showList = false" @keydown="handleKeydown($event)" x-ref="searchInput" spellcheck="false" autocomplete="off">
          <div x-show="showList && filteredOptions.length" x-ref="dropdown" :style="dropdownStyle" x-cloak :class="{'hidden': !dropdownVisible}" class="fixed z-[70] max-h-40 overflow-auto text-base p-2 list-none bg-white divide-y divide-gray-100 rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 whitespace-nowrap">
            <ul class="list-none" role="listbox" :id="_listboxId">
              <template x-for="(option, index) in filteredOptions" :key="index">
                <li @click="selectOption(option)" :id="`${_listboxId}-opt-${index}`" role="option" :aria-selected="selectedIndex === index" :class="{'bg-blue-100 dark:bg-blue-900': selectedIndex === index}" class="my-1 cursor-pointer nav-item text-sm">
                  <img x-show="option.url.length" :src="option.url" alt="Icon" class="size-10 mr-2">
                  <div x-text="option.description + ' (' + option.source + ')'"></div>
                </li>
              </template>
            </ul>
          </div>
        </div>
        <button type="button" class="ml-2 text-gray-900 dark:text-white" @click="clear()" x-show="formData.icon_url.length" aria-label="Clear Icon">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6" aria-hidden="true" >
            <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </button>
      </div>
    </div>
    <div>
      <div class="flex items-center mb-1">
        <label class="form-label mb-0 mr-2">Additional Space Names</label>
        <button type="button" x-on:click="addAltName()" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg text-sm p-2.5">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true" >
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          <span class="sr-only">Add</span>
        </button>
      </div>
      <template x-for="(name, index) in formData.alt_names" :key="index">
        <div class="mb-2">
          <div class="flex items-center">
            <input type="text" class="form-field mr-2" x-model="formData.alt_names[index]" x-on:keyup.debounce.500ms="checkAltName(index)" :class="{'form-field-error': !altNameValid[index]}" placeholder="Additional space name" aria-label="Additional space name">
            <button type="button" x-on:click="removeAltName(index)" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg text-sm p-2.5">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true" >
                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
              </svg> <span class="sr-only">Remove</span>
            </button>
          </div>
          <div x-show="!altNameValid[index]" class="error-message">Space names can only contain the letters a - Z, 0 - 9 and -, max 64 characters.</div>
        </div>
      </template>
    </div>
    <div>
      <label for="shell" class="form-label">Terminal Shell</label>
      <select class="form-field" name="shell" id="shell" x-model="formData.shell">
        <option value="bash">Bash</option>
        <option value="zsh">Zsh</option>
        <option value="fish">fish</option>
        <option value="sh">Bourne</option>
      </select>
      <div class="description">The shell that will be used when you open a web terminal in this space.</div>
    </div>
    <div x-show="!isManual" x-cloak>
      <div x-data="autocompleterScript()" data-parent-var-group="formData" data-parent-variable="startup_script_id" @refresh-autocompleter.window="refresh()" x-id="['dropdown']">
        <label for="startup_script_id" class="form-label">User Startup Script</label>
        <div class="flex items-center">
          <div class="relative w-full">
            <input id="startup_script_id" x-model="search" class="form-field" type="search" placeholder="Search your scripts..." role="combobox" :aria-expanded="showList && filteredOptions.length > 0" :aria-activedescendant="activeDescendant" :aria-controls="_listboxId" @focus="handleFocus()" @blur.debounce.200ms="showList = false" @keydown="handleKeydown($event)" x-ref="searchInput" spellcheck="false" autocomplete="off">
            <div x-show="showList && filteredOptions.length" x-ref="dropdown" :style="dropdownStyle" x-cloak :class="{'hidden': !dropdownVisible}" class="fixed z-[70] max-h-40 overflow-auto text-base p-2 list-none bg-white divide-y divide-gray-100 rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 whitespace-nowrap">
              <ul class="list-none" role="listbox" :id="_listboxId">
                <template x-for="(option, index) in filteredOptions" :key="index">
                  <li @click="selectOption(option)" :id="`${_listboxId}-opt-${index}`" role="option" :aria-selected="selectedIndex === index" :class="{'bg-blue-100 dark:bg-blue-900': selectedIndex === index}" class="my-1 cursor-pointer nav-item text-sm px-2 py-1">
                    <div x-text="option.name"></div>
                  </li>
                </template>
              </ul>
            </div>
          </div>
          <button type="button" class="ml-2 text-gray-900 dark:text-white" @click="clear()" x-show="formData.startup_script_id.length" aria-label="Clear Script">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="m9.75 9.75 4.5 4.5m0-4.5-4.5 4.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
          </button>
        </div>
        <div class="description">Optional user script to run after system startup script</div>
      </div>
    </div>
    <div>
      <fieldset class="rounded-lg p-3 border border-gray-200 dark:border-gray-700">
        <legend class="text-md font-medium text-gray-900 dark:text-white">Space Dependencies</legend>
        <div class="flex items-center justify-between gap-4 mb-3">
          <div class="description">Selected spaces must already be running before this space can start. Knot will not auto-start them.</div>
          <button type="button" @click="openDependencyModal()" class="text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-500 rounded-lg text-sm p-2.5 shrink-0" :disabled="!dependencyOptions.length" aria-label="Add dependency">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4" aria-hidden="true" >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </button>
        </div>
        <div class="rounded-lg border border-gray-200 dark:border-gray-700 divide-y divide-gray-200 dark:divide-gray-700">
          <template x-if="selectedDependencies().length">
            <div>
              <template x-for="dependency in selectedDependencies()" :key="dependency.id">
                <div class="flex items-center justify-between px-4 py-3 gap-4">
                  <div class="min-w-0">
                    <div class="text-sm font-medium text-gray-900 dark:text-white" x-text="dependency.name"></div>
                    <div class="text-sm text-gray-500 dark:text-gray-400" x-text="dependencyDescription(dependency)"></div>
                  </div>
                  <button @click="openRemoveDependencyConfirm(dependency)" type="button" class="text-sm text-red-600 hover:text-red-700 dark:text-red-400 dark:hover:text-red-300">Remove</button>
                </div>
              </template>
            </div>
          </template>
          <template x-if="!selectedDependencies().length">
            <div class="px-4 py-3 text-sm text-gray-500 dark:text-gray-400">No dependencies configured.</div>
          </template>
        </div>
      </fieldset>
    </div>
    <div x-show="!isManual && template.custom_fields.length" x-cloak>
      <fieldset class="rounded-lg p-3 border border-gray-200 dark:border-gray-700">
        <legend class="text-md font-medium text-gray-900 dark:text-white">Custom Fields</legend>
        <div class="space-y-6">
          <template x-for="(field, index) in template.custom_fields" :key="index">
            <div>
              <label class="form-label" x-text="template.custom_fields[index].description + ' (' + template.custom_fields[index].name + ')'"></label>
              <input type="text" class="form-field" placeholder="Field value" x-model="formData.custom_fields[index].value" :aria-label="template.custom_fields[index].description + ' value'">
            </div>
          </template>
        </div>
      </fieldset>
    </div>
    <div x-show="spaceFormModal.isEdit && formData.created_at_formatted" x-cloak>
      <label for="created_at" class="form-label">Created</label>
      <input type="text" class="form-field bg-gray-50 dark:bg-gray-700 cursor-not-allowed" name="created_at" id="created_at" :value="formatCreatedAt()" readonly tabindex="-1">
      <div class="description">The date and time when this space was originally created.</div>
    </div>
    <div x-cloak x-show="!spaceFormModal.isEdit && !isManual">
      <label class="flex items-center cursor-pointer mb-2">
        <input type="checkbox" class="sr-only peer" value="1" x-model="startOnCreate" :checked="startOnCreate">
        <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
        <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Start Space on Create</span>
      </label>
    </div>
    <div class="form-actions">
      <button type="button" @click="spaceFormModal.show = false" class="form-cancel" x-text="isEdit ? 'Discard' : 'Cancel'"></button>
      <button type="submit" class="btn-primary" :disabled="loading || saving" x-text="saving ? buttonLabelWorking : (isEdit ? 'Save' : 'Create')"></button>
    </div>
  </form>
  <div x-cloak x-show="dependencyModal.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="dependencyModal.show" @keydown.esc.window="closeDependencyModal()" @click.self="closeDependencyModal()" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="dependencyModalTitle">
    <div x-show="dependencyModal.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel">
      <div class="ui-modal-header">
        <div class="ui-modal-icon-info">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5" aria-hidden="true" >
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m6-6H6" />
          </svg>
        </div>
        <h3 id="dependencyModalTitle" class="ui-modal-title">Add Dependency</h3>
        <button @click="closeDependencyModal()" aria-label="close modal" class="ui-modal-close">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="ui-modal-body">
        <p>Select a space in the same zone to add as a dependency.</p>
        <div x-data="autocompleterSpace()" x-init="setDataSource('dependencyOptions')" data-parent-var-group="dependencyModal" data-parent-variable="selectedId" data-parent-variable-name="selectedName" @refresh-space-autocompleter.window="refresh()" @space-selected="dependencyModal.invalid = false" class="relative mt-4">
          <input x-model="search" class="form-field" type="search" placeholder="Search spaces..." aria-label="Search spaces" role="combobox" :aria-expanded="showList && filteredOptions.length > 0" :aria-activedescendant="activeDescendant" :aria-controls="_listboxId" @focus="handleFocus()" @blur.debounce.200ms="showList = false" @keydown="handleKeydown($event)" x-ref="searchInput" x-init="$nextTick(() => $refs.searchInput.focus())" autofocus>
          <div x-show="showList && filteredOptions.length" x-ref="dropdown" :style="dropdownStyle" x-cloak :class="{'hidden': !dropdownVisible}" class="fixed z-[70] max-h-40 overflow-x-hidden overflow-y-auto text-base p-2 list-none bg-white divide-y divide-gray-100 rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 block">
            <ul class="list-none" role="listbox" :id="_listboxId">
              <template x-for="(option, index) in filteredOptions" :key="option.id">
                <li @click="selectOption(option)" :id="`${_listboxId}-opt-${index}`" role="option" :aria-selected="selectedIndex === index" :class="{'bg-blue-100 dark:bg-blue-900': selectedIndex === index}" class="my-1 cursor-pointer nav-item text-sm px-2 py-1 overflow-hidden">
                  <div class="flex min-w-0 flex-col gap-1">
                    <div class="font-medium truncate" x-text="option.name"></div>
                    <div class="text-xs text-gray-500 dark:text-gray-400 truncate" x-text="dependencyDescription(option)"></div>
                  </div>
                </li>
              </template>
            </ul>
          </div>
        </div>
        <div x-show="dependencyModal.invalid" class="error-message mt-2" x-cloak>Select a valid space.</div>
        <div x-show="!dependencyOptions.length" class="text-sm text-gray-500 dark:text-gray-400 mt-3" x-cloak>No more spaces are available in this zone.</div>
      </div>
      <div class="ui-modal-footer">
        <button @click="closeDependencyModal()" type="button" class="ui-button-secondary">Cancel</button>
        <button @click="addDependency()" type="button" class="ui-button-primary" :disabled="!dependencyOptions.length || dependencyModal.selectedId === ''">
          <span x-text="dependencyModal.selectedName ? 'Add ' + dependencyModal.selectedName : 'Add'"></span>
        </button>
      </div>
    </div>
  </div>
  <div x-cloak x-show="dependencyRemoveConfirm.show" x-transition.opacity.duration.200ms x-trap.inert.noscroll="dependencyRemoveConfirm.show" @keydown.esc.window="closeRemoveDependencyConfirm()" @click.self="closeRemoveDependencyConfirm()" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="dependencyRemoveConfirmTitle">
    <div x-show="dependencyRemoveConfirm.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel">
      <div class="ui-modal-header">
        <div class="ui-modal-icon-danger">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-6" aria-hidden="true" >
            <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 id="dependencyRemoveConfirmTitle" class="ui-modal-title">Remove Dependency</h3>
        <button @click="closeRemoveDependencyConfirm()" aria-label="close modal" class="ui-modal-close">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="ui-modal-body text-center">
        <p>Are you sure you want to remove the dependency <strong x-text="dependencyRemoveConfirm.name"></strong>?</p>
        <p>This space will no longer require it to be running before start.</p>
      </div>
      <div class="ui-modal-footer">
        <button @click="closeRemoveDependencyConfirm()" type="button" class="ui-button-secondary">Keep Dependency</button>
        <button @click="confirmRemoveDependency()" type="button" class="ui-button-danger">Remove Dependency</button>
      </div>
    </div>
  </div>
  <div x-cloak x-show="quotaStorageLimitShow" x-transition.opacity.duration.200ms x-trap.inert.noscroll="quotaStorageLimitShow" @keydown.esc.window="quotaStorageLimitShow = false" @click.self="quotaStorageLimitShow = false" class="ui-modal-backdrop" role="dialog" aria-modal="true" aria-labelledby="quotaStorageLimitTitle">
    <div x-show="quotaStorageLimitShow" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100" class="ui-modal-panel">
      <div class="ui-modal-header">
        <div class="ui-modal-icon-danger">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-6" aria-hidden="true" >
            <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 id="quotaStorageLimitTitle" class="ui-modal-title">Storage Quota Exceeded</h3>
        <button @click="quotaStorageLimitShow = false" aria-label="close modal" class="ui-modal-close">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke="currentColor" fill="none" stroke-width="1.4" class="w-5 h-5" aria-hidden="true" >
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="ui-modal-body text-center">
        <p>Creating this space would exceed your storage quota.</p>
        <p>You can stop and delete another space to reduce your storage usage or contact your administrator to increase your quota.</p>
      </div>
      <div class="ui-modal-footer">
        <button @click="quotaStorageLimitShow = false" type="button" class="ui-button-danger">Dismiss</button>
      </div>
    </div>
  </div>
</div>
{{ end }}
