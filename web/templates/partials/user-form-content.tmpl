{{ define "user-form-content" }}
<div x-data="userForm(userFormModal.isEdit, userFormModal.userId, {{ if .isProfile }}true{{ else }}false{{ end }}, {{ if .isProfile }}{{ .allProviders }}{{ else }}null{{ end }})" x-init="initUsers">
<div class="grid gap-4" :class="userFormModal.isEdit ? 'grid-cols-1 lg:grid-cols-2' : 'grid-cols-1'">
  <div>
      {{ template "loading" . }}
      <form class="space-y-6" action="" method="POST" @submit.prevent="submitData" x-show="!loading" x-cloak>
        <fieldset class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">General</legend>
          <div class="space-y-6">
            <div>
              <label for="username" class="form-label">Username</label>
              <input type="text" id="username" class="form-field" name="username" x-on:keyup.debounce.500ms="checkUsername()" :class="{'form-field-error': !usernameValid}" placeholder="Username (a - Z, 0 - 9, - and .)" x-model="formData.username" {{ if .isEdit }}readonly{{ end }}>
              <div x-show="!usernameValid" class="error-message" x-cloak>Username can only contain the letters a - Z, 0 - 9, - and ., max 64 characters.</div>
            </div>
            <div>
              <label for="email" class="form-label">Email</label>
              <input type="email" id="email" class="form-field" name="email" x-on:keyup.debounce.500ms="checkEmail()" :class="{'form-field-error': !emailValid}" placeholder="Email address" x-model="formData.email">
              <div x-show="!emailValid" class="error-message" x-cloak>Enter a valid email address.</div>
            </div>
            <div>
              <label for="shell" class="form-label">Preferred Shell</label>
              <select id="shell" class="form-field" name="shell" x-model="formData.preferred_shell">
                <option value="bash">Bash</option>
                <option value="zsh">Zsh</option>
                <option value="fish">fish</option>
                <option value="sh">Bourne</option>
              </select>
              <p class="description">The shell that will be used when you open a web terminal in this space.</p>
              <div x-show="!shellValid" class="error-message" x-cloak>Select a valid shell.</div>
            </div>
            <div>
              <label for="tz" class="form-label">Timezone</label>
              <div x-data="autocompleter()" x-init="setData(window.Timezones)" data-parent-variable="timezone" @refresh-autocompleter.window="refresh()" class="relative">
                <input id="tz" x-model="search" class="form-field" type="search" placeholder="Search..." @focus="handleFocus()" @blur.debounce.200ms="showList = false" @keydown="handleKeydown($event)">
                <div x-show="showList && filteredOptions.length" x-cloak class="max-h-40 overflow-auto absolute z-50 my-1 text-base p-2 list-none bg-white divide-y divide-gray-100 rounded-lg shadow-xl border border-gray-200 dark:bg-gray-800 dark:border-gray-700 dark:divide-gray-600 block whitespace-nowrap">
                  <ul class="list-none">
                    <template x-for="(option, index) in filteredOptions" :key="index">
                      <li @click="selectOption(option)" x-text="option" :class="{'bg-blue-100 dark:bg-blue-900': selectedIndex === index}" class="my-1 cursor-pointer nav-item text-sm"></li>
                    </template>
                  </ul>
                </div>
              </div>
              <div x-show="!tzValid" class="error-message">Enter a valid Timezone.</div>
            </div>
          </div>
        </fieldset>

        <fieldset class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Authentication</legend>
          <div class="space-y-6">
            <div>
              <label for="github_username" class="form-label">GitHub Username</label>
              <input type="text" id="github_username" class="form-field" name="github_username" x-on:keyup.debounce.500ms="checkGithubUsername()" :class="{'form-field-error': !githubUsernameValid}" placeholder="GitHub Username" x-model="formData.github_username">
              <p class="description">If the GitHub username is given then the public SSH keys are loaded from it by the agent.</p>
              <div x-show="!githubUsernameValid" class="error-message" x-cloak>Enter a valid GitHub username.</div>
            </div>
            <div>
              <label for="ssh_key" class="form-label">SSH Public Key</label>
              <textarea id="ssh_key" class="form-field" name="ssh_key" rows="8" placeholder="SSH Public Key" x-model="formData.ssh_public_key"></textarea>
              <p class="description">If given this key will be added to the spaces to allow you to SSH into the space.</p>
            </div>
            <div>
              <label for="password" class="form-label">Password</label>
              <input type="password" id="password" class="form-field" name="password" x-on:keyup.debounce.500ms="checkPassword()" :class="{'form-field-error': !passwordValid}" placeholder="Password" x-model="formData.password">
              {{ if .isProfile }}
              <p class="description">Leave blank to keep the current password.</p>
              {{ end }}
              <div x-show="!passwordValid" class="error-message" x-cloak>Password must be at least 8 characters.</div>
            </div>
            <div>
              <label for="confirm_password" class="form-label">Confirm Password</label>
              <input type="password" id="confirm_password" class="form-field" name="confirm_password" x-on:keyup.debounce.500ms="checkConfirmPassword()" :class="{'form-field-error': !confirmPasswordValid}" placeholder="Confirm password" x-model="formData.password_confirm">
              <div x-show="!confirmPasswordValid" class="error-message" x-cloak>Both passwords must match.</div>
            </div>
            {{ if .isProfile }}
            <div>
              <label for="service_password" class="form-label">Service Password</label>
              <input type="text" id="service_password" class="form-field" name="service_password" x-on:keyup.debounce.500ms="checkServicePassword()" :class="{'form-field-error': !servicePasswordValid}" placeholder="Service Password" x-model="formData.service_password">
              <p class="description">A password made available for initializing services such as databases.</p>
              <div x-show="!servicePasswordValid" class="error-message" x-cloak>The service password is required.</div>
            </div>
            {{ end }}
          </div>
        </fieldset>

        {{ if and (not .isProfile) .permissionManageUsers }}
        <fieldset class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
          <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Account</legend>
          <div class="space-y-6">
            <div x-show="isEdit && formData.user_id !== '{{ .user.id }}'" x-cloak>
              <label class="flex items-center cursor-pointer mb-2">
                <input type="checkbox" id="active" name="active" x-model="formData.active" class="sr-only peer">
                <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300">Active</span>
              </label>
            </div>
            <div class="grid gap-4 md:grid-cols-2">
              <div>
                <label for="max_spaces" class="form-label">Maximum Spaces</label>
                <input type="number" id="max_spaces" class="form-field" name="max_spaces" x-model="formData.max_spaces" min="0" max="10000" x-on:keyup.debounce.500ms="checkMaxSpaces()" :class="{'form-field-error': !maxSpacesValid}" >
                <p class="description">The maximum number of spaces this user can create, 0 for unlimited.</p>
                <div x-show="!maxSpacesValid" class="error-message" x-cloak>Enter a valid number between 0 and 10,000.</div>
              </div>
              <div>
                <label for="compute_units" class="form-label">Compute Units Limit</label>
                <input type="number" id="compute_units" class="form-field" name="compute_units" x-model="formData.compute_units" min="0" x-on:keyup.debounce.500ms="checkComputeUnits()" :class="{'form-field-error': !computeUnitsValid}" >
                <p class="description">The maximum number of compute units (CPU, GPU, RAM, etc.) this user can use, 0 for unlimited.</p>
                <div x-show="!computeUnitsValid" class="error-message" x-cloak>Enter a valid number >= 0.</div>
              </div>
              <div>
                <label for="storage_units" class="form-label">Storage Units Limit</label>
                <input type="number" id="storage_units" class="form-field" name="storage_units" x-model="formData.storage_units" min="0" x-on:keyup.debounce.500ms="checkStorageUnits()" :class="{'form-field-error': !storageUnitsValid}" >
                <p class="description">The maximum number of storage units this user can use, 0 for unlimited.</p>
                <div x-show="!storageUnitsValid" class="error-message" x-cloak>Enter a valid number >= 0.</div>
              </div>
              <div>
                <label for="max_tunnels" class="form-label">Maximum Tunnels</label>
                <input type="number" id="max_tunnels" class="form-field" name="max_tunnels" x-model="formData.max_tunnels" min="0" x-on:keyup.debounce.500ms="checkMaxTunnels()" :class="{'form-field-error': !maxTunnelsValid}" >
                <p class="description">The maximum number of tunnels this user can create, 0 for unlimited.</p>
                <div x-show="!maxTunnelsValid" class="error-message" x-cloak>Enter a valid number between 0 and 100.</div>
              </div>
            </div>
            <div class="grid grid-cols-1 xl:grid-cols-2 xl:gap-4">
              <div x-show="roles.length" x-cloak>
                <label class="form-label">Roles</label>
                <template x-for="(role, index) in roles" :key="index">
                  <label class="flex items-center cursor-pointer mb-2">
                    <input type="checkbox" class="sr-only peer" :id="'role-' + index" name="roles[]" :value="role.role_id" :checked="formData.roles.includes(role.role_id)" @change="toggleRole(role.role_id)">
                    <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                    <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300" x-text="role.name"></span>
                  </label>
                </template>
              </div>
              <div x-show="groups.length" x-cloak>
                <label class="form-label">Groups</label>
                <template x-for="(group, index) in groups" :key="index">
                  <label class="flex items-center cursor-pointer mb-2">
                    <input type="checkbox" class="sr-only peer" :id="'group-' + index" name="groups[]" :value="group.group_id" :checked="formData.groups.includes(group.group_id)" @change="toggleGroup(group.group_id)">
                    <div class="relative w-9 h-5 bg-gray-200 peer-focus:outline-hidden peer-focus:ring-4 peer-focus:ring-blue-300 dark:peer-focus:ring-blue-800 rounded-full peer dark:bg-gray-700 peer-checked:after:translate-x-full peer-checked:rtl:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all dark:border-gray-600 peer-checked:bg-blue-600 peer-checked:dark:bg-blue-600"></div>
                    <span class="ms-3 text-sm font-medium text-gray-900 dark:text-gray-300" x-text="group.name"></span>
                  </label>
                </template>
              </div>
            </div>
          </div>
        </fieldset>
        {{ end }}

        {{ if .isProfile }}
        <div x-show="isEdit && (Object.keys(formData.external_auth_providers || {}).length > 0 || linkableProviders.length > 0)" x-cloak>
          <fieldset class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
            <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Connected Accounts</legend>
            <ul class="space-y-2 mt-1" x-show="Object.keys(formData.external_auth_providers || {}).length > 0">
              <template x-for="[providerID, ep] in Object.entries(formData.external_auth_providers || {})" :key="providerID">
                <li class="flex items-center justify-between text-sm text-gray-700 dark:text-gray-300">
                  <div class="flex items-center gap-2">
                    <span class="font-medium capitalize" x-text="providerID"></span>
                    <span class="text-gray-400">&middot;</span>
                    <span class="font-mono" x-text="ep.username"></span>
                  </div>
                  <template x-if="formData.has_password">
                    <button type="button"
                      @click="confirmUnlinkProvider(providerID, providerID)"
                      class="group flex items-center cursor-pointer whitespace-nowrap rounded-lg bg-red-700 hover:bg-red-800 px-4 py-2 text-center text-sm font-medium tracking-wide text-neutral-100 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-black active:opacity-100 active:outline-offset-0 dark:text-white dark:bg-red-600 dark:hover:bg-red-700 dark:focus-visible:outline-white">Unlink</button>
                  </template>
                </li>
              </template>
            </ul>
            <template x-if="!formData.has_password">
              <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Set a password to enable unlinking.</p>
            </template>
            <div class="flex flex-wrap gap-2 mt-2" x-show="linkableProviders.length > 0">
              <template x-for="p in linkableProviders" :key="p.id">
                <a :href="`/auth/${p.id}/start?link=true&redirect=/profile`"
                   @click="p.linking = true"
                   class="group flex items-center gap-2 cursor-pointer whitespace-nowrap rounded-lg bg-blue-700 hover:bg-blue-800 px-4 py-2 text-center text-sm font-medium tracking-wide text-neutral-100 transition dark:bg-blue-600 dark:hover:bg-blue-700">
                  <svg x-show="p.linking" class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
                  </svg>
                  <span x-text="p.linking ? 'Connecting\u2026' : 'Link ' + p.display_name"></span>
                </a>
              </template>
            </div>
          </fieldset>
        </div>
        {{ else }}
        <div x-show="isEdit && Object.keys(formData.external_auth_providers || {}).length > 0" x-cloak>
          <fieldset class="rounded-lg p-4 border border-gray-200 dark:border-gray-700">
            <legend class="text-sm font-medium text-gray-900 dark:text-white px-2">Linked Accounts</legend>
            <ul class="space-y-2 mt-1">
              <template x-for="[providerID, ep] in Object.entries(formData.external_auth_providers || {})" :key="providerID">
                <li class="flex items-center justify-between text-sm text-gray-700 dark:text-gray-300">
                  <div class="flex items-center gap-2">
                    <span class="font-medium capitalize" x-text="providerID"></span>
                    <span class="text-gray-400">&middot;</span>
                    <span class="font-mono" x-text="ep.username"></span>
                  </div>
                  <button type="button"
                    @click="confirmUnlinkProvider(providerID, providerID)"
                    class="group flex items-center cursor-pointer whitespace-nowrap rounded-lg bg-red-700 hover:bg-red-800 px-4 py-2 text-center text-sm font-medium tracking-wide text-neutral-100 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-black active:opacity-100 active:outline-offset-0 dark:text-white dark:bg-red-600 dark:hover:bg-red-700 dark:focus-visible:outline-white">Unlink</button>
                </li>
              </template>
            </ul>
          </fieldset>
        </div>
        {{ end }}

        <div x-show="isEdit" x-cloak class="text-xs text-gray-400 dark:text-gray-500">
          Last login <span x-text="last_login_at"></span>
        </div>

        <!-- Reset TOTP confirm modal -->
        <div x-show="resetConfirmShow" x-cloak x-transition.opacity.duration.200ms
          x-trap.inert.noscroll="resetConfirmShow"
          @keydown.esc.window="resetConfirmShow = false"
          @click.self="resetConfirmShow = false"
          class="ui-modal-backdrop"
          role="dialog" aria-modal="true">
          <div x-show="resetConfirmShow" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100"
            class="ui-modal-panel">
            <div class="ui-modal-header">
              <div class="ui-modal-icon-danger">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-6" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z" clip-rule="evenodd" />
                </svg>
              </div>
              <h3 class="ui-modal-title">Reset TOTP?</h3>
            </div>
            <div class="ui-modal-body">
              <p class="text-sm">The user will need to set up TOTP again on next login.</p>
            </div>
            <div class="ui-modal-footer">
              <button @click="resetConfirmShow = false" type="button" class="ui-button-secondary">Cancel</button>
              <button @click="resetTOTP()" type="button" class="ui-button-danger">Reset</button>
            </div>
          </div>
        </div>

        <!-- Unlink confirm modal -->
        <div x-show="unlinkConfirm.show" x-cloak x-transition.opacity.duration.200ms
          x-trap.inert.noscroll="unlinkConfirm.show"
          @keydown.esc.window="unlinkConfirm.show = false"
          @click.self="unlinkConfirm.show = false"
          class="ui-modal-backdrop"
          role="dialog" aria-modal="true">
          <div x-show="unlinkConfirm.show" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-95 opacity-0" x-transition:enter-end="scale-100 opacity-100"
            class="ui-modal-panel">
            <div class="ui-modal-header">
              <div class="ui-modal-icon-danger">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-6" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z" clip-rule="evenodd" />
                </svg>
              </div>
              <h3 class="ui-modal-title">Unlink <span class="capitalize" x-text="unlinkConfirm.providerName"></span>?</h3>
            </div>
            <div class="ui-modal-body">
              <p class="text-sm">You will no longer be able to sign in with this account.</p>
            </div>
            <div class="ui-modal-footer">
              <button @click="unlinkConfirm.show = false" type="button" class="ui-button-secondary">Cancel</button>
              <button @click="unlinkProvider()" type="button" class="ui-button-danger">Unlink</button>
            </div>
          </div>
        </div>

      </form>
  </div>
  <template x-if="userFormModal.isEdit">
    <div x-data="usageComponent(userFormModal.userId)">
    <div class="h-72">
      <canvas id="spaceUsage" aria-label="Space usage chart" role="img">Space usage chart</canvas>
    </div>
    <div class="h-72">
      <canvas id="tunnelUsage" aria-label="Tunnel usage chart" role="img">Tunnel usage chart</canvas>
    </div>
    <div class="h-72">
      <canvas id="computeUsage" aria-label="Compute usage chart" role="img">Compute usage chart</canvas>
    </div>
    <div class="h-72">
      <canvas id="storageUsage" aria-label="Storage usage chart" role="img">Storage usage chart</canvas>
    </div>
    </div>
  </template>
</div>
<div class="mt-4 flex {{ if not .isProfile }}justify-between{{ else }}justify-end{{ end }} gap-2 pt-4 border-t border-neutral-300 dark:border-gray-700">
  {{ if not .isProfile }}
  <button type="button" @click="userFormModal.show = false" class="cursor-pointer whitespace-nowrap rounded-lg px-4 py-2 text-center text-sm font-medium tracking-wide text-neutral-600 transition hover:bg-gray-100 dark:text-neutral-300 dark:hover:bg-gray-700" x-text="isEdit ? 'Discard' : 'Cancel'"></button>
  {{ end }}

  <div class="flex gap-2">
    {{ if and .isProfile .totpEnabled }}
    <button type="button" class="btn-primary" value="TOTP" x-show="isEdit && formData.totp_secret.length" x-on:click="showTOTP = true">Show TOTP</button>
    {{ end }}

    {{ if and (not .isProfile) .totpEnabled }}
    <button @click="resetConfirmShow = true;" type="button" x-show="isEdit && formData.totp_secret.length" class="cursor-pointer whitespace-nowrap rounded-lg bg-red-700 hover:bg-red-800 px-4 py-2 text-center text-sm font-medium tracking-wide text-neutral-100 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-black active:opacity-100 active:outline-offset-0 dark:text-white dark:bg-red-600 dark:hover:bg-red-700 dark:focus-visible:outline-white">Reset TOTP</button>
    {{ end }}

    <button type="submit" @click="submitData" class="btn-primary" x-text="isEdit ? 'Save' : 'Create'"></button>
  </div>
</div>
</div>
{{ end }}
