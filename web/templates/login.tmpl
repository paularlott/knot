{{ template "layout-login.tmpl" . }}

{{ define "pageTitle" }}Sign In{{ end }}

{{ define "mainContent" }}
<div class="w-full max-w-md p-6 space-y-8 sm:p-8 bg-white rounded-lg shadow-2xl dark:bg-gray-800" x-data="loginUserForm('{{ .redirect }}')">
  <div class="flex items-center justify-center mb-8 text-3xl font-semibold lg:mb-10 dark:text-white">
    {{ if .logoURL }}
    <img src="{{ .logoURL }}" class="h-11 {{ if .logoInvert }}dark:brightness-0 dark:invert{{ end }}" alt="Logo">
    {{ else }}
    <img src="images/logo.svg" class="mr-4 h-11" alt="knot logo"> Sign in to Knot
    {{ end }}
  </div>

  {{ if .passwordAuthEnabled }}
  <form class="mt-8 mb-0 space-y-6" action="#" action="" method="POST" @submit.prevent="submitData">
    <div class="auth-form-panel">
      <div class="mb-5">
        <h2 class="auth-form-heading">Sign in with email</h2>
        <p class="auth-form-caption">Use your Knot account credentials to continue into your workspace.</p>
      </div>

      <div class="space-y-4">
        <div>
          <label for="email" class="form-label">Email</label>
          <div class="auth-form-field-shell">
            <div class="auth-form-field-icon" aria-hidden="true">
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M21.75 7.5v9A2.25 2.25 0 0 1 19.5 18.75h-15A2.25 2.25 0 0 1 2.25 16.5v-9m19.5 0A2.25 2.25 0 0 0 19.5 5.25h-15A2.25 2.25 0 0 0 2.25 7.5m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.92l-7.5 4.615a2.25 2.25 0 0 1-2.36 0l-7.5-4.615a2.25 2.25 0 0 1-1.07-1.92V7.5" />
              </svg>
            </div>
            <input type="email" name="email" id="email" class="auth-form-field" placeholder="name@company.com" required="" x-on:keyup.debounce.500ms="checkEmail()" x-model="formData.email" :class="{'form-field-error': !emailValid}">
          </div>
          <div class="error-message mt-2" x-show="!emailValid" x-cloak>Enter a valid email address.</div>
        </div>

        <div>
          <label for="password" class="form-label">Password</label>
          <div class="auth-form-field-shell">
            <div class="auth-form-field-icon" aria-hidden="true">
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 0h10.5A2.25 2.25 0 0 1 19.5 12.75v6A2.25 2.25 0 0 1 17.25 21h-10.5A2.25 2.25 0 0 1 4.5 18.75v-6A2.25 2.25 0 0 1 6.75 10.5Z" />
              </svg>
            </div>
            <input type="password" name="password" id="password" placeholder="your password" class="auth-form-field" required="" x-on:keyup.debounce.500ms="checkPassword()" x-model="formData.password" :class="{'form-field-error': !passwordValid}">
          </div>
          <div class="error-message mt-2" x-show="!passwordValid" x-cloak>Enter your password.</div>
        </div>

        {{ if .totpEnabled }}
        <div>
          <label for="totp" class="form-label">One Time Password</label>
          <div class="auth-form-field-shell">
            <div class="auth-form-field-icon" aria-hidden="true">
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M15.75 5.25V3.75m-7.5 1.5V3.75m12 4.5v10.5A2.25 2.25 0 0 1 18 21H6a2.25 2.25 0 0 1-2.25-2.25V8.25m16.5 0A2.25 2.25 0 0 0 18 6H6a2.25 2.25 0 0 0-2.25 2.25m16.5 0v.75A2.25 2.25 0 0 1 18 11.25H6A2.25 2.25 0 0 1 3.75 9V8.25m5.25 5.25h6" />
              </svg>
            </div>
            <input type="text" name="totp" id="totp" placeholder="123456" class="auth-form-field" x-model="formData.totp_code">
          </div>
        </div>
        {{ end }}
      </div>

      <div class="mt-5">
        <button type="submit" class="auth-form-submit flex items-center justify-center gap-2" :disabled="loading">
          <svg x-show="loading" class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
          </svg>
          <span x-text="buttonLabel"></span>
        </button>
        <p class="mt-3 text-center text-xs text-gray-500 dark:text-gray-400">Secure sign-in with your Knot account credentials.</p>
      </div>
    </div>
  </form>
  {{ end }}

  {{ if .authProviders }}
  <div class="mt-4">
    {{ if .passwordAuthEnabled }}
    <div class="relative flex items-center">
      <div class="flex-grow border-t border-gray-300 dark:border-gray-600"></div>
      <span class="mx-3 text-sm text-gray-500 dark:text-gray-400">or continue with</span>
      <div class="flex-grow border-t border-gray-300 dark:border-gray-600"></div>
    </div>
    {{ end }}
    <div class="mt-4 flex flex-col gap-2" x-data="{ linking: null }">
      {{ range .authProviders }}
      <a href="/auth/{{ .ID }}/start?redirect={{ $.redirect }}"
         @click="linking = '{{ .ID }}'"
         class="flex items-center justify-center gap-2 w-full px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 dark:bg-gray-700 dark:text-gray-200 dark:border-gray-600 dark:hover:bg-gray-600 transition-colors">
        <svg x-show="linking === '{{ .ID }}'" class="animate-spin h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" aria-hidden="true">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        <span x-text="linking === '{{ .ID }}' ? 'Signing in…' : 'Sign in with {{ .DisplayName }}'"></span>
      </a>
      {{ end }}
    </div>
  </div>
  {{ end }}

  <!-- Modal -->
  <div x-cloak x-show="showTOTP" x-transition.opacity.duration.200ms x-trap.inert.noscroll="showTOTP" @keydown.esc.window="showTOTP = false" @click.self="showTOTP = false" class="fixed top-0 left-0 right-0 bottom-0 inset-0 z-[60] flex items-end justify-center bg-black/20 p-4 pb-8 backdrop-blur-xs sm:items-center lg:p-8" role="dialog" aria-modal="true" aria-labelledby="totpModalTitle">
    <!-- Modal Dialog -->
    <div x-show="showTOTP" x-transition:enter="transition ease-out duration-200 delay-100 motion-reduce:transition-opacity" x-transition:enter-start="scale-0" x-transition:enter-end="scale-100" class="flex max-w-lg flex-col gap-4 overflow-hidden rounded-lg border border-grey-200 bg-white text-neutral-600 dark:bg-gray-800 dark:border-gray-700 dark:text-neutral-300 shadow-xl">
      <!-- Dialog Header -->
      <div class="flex items-center justify-between border-b border-neutral-300 bg-neutral-50/60 p-4 dark:border-gray-700 dark:bg-gray-800/20">
        <div class="flex items-center justify-center rounded-full bg-red-500/20 text-red-500 p-1">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="size-6" aria-hidden="true" >
            <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16ZM8.28 7.22a.75.75 0 0 0-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 1 0 1.06 1.06L10 11.06l1.72 1.72a.75.75 0 1 0 1.06-1.06L11.06 10l1.72-1.72a.75.75 0 0 0-1.06-1.06L10 8.94 8.28 7.22Z" clip-rule="evenodd" />
          </svg>
        </div>
        <h3 id="totpModalTitle" class="font-semibold tracking-wide text-neutral-900 dark:text-white">One Time Password</h3>
        <div></div>
      </div>
      <!-- Dialog Body -->
      <div class="px-4 py-4 text-center">
        <p>This system has one time passwords enabled, please scan or record this code within your authenticator app:<br /><br /><strong x-text="totpSecret"></strong></p>
        <template x-if="totpSecret.length">
          <img :src="'/qrcode/' + totpSecret" alt="QR Code" class="w-48 h-48 mx-auto mt-4">
        </template>
        <p class="mt-4">The code will be available from your profile page.</p>
      </div>
      <!-- Dialog Footer -->
      <div class="flex flex-col-reverse justify-between gap-2 border-t border-neutral-300 bg-neutral-50/60 p-4 dark:border-gray-700 dark:bg-gray-800/20 sm:flex-row sm:items-center md:justify-end">
          <button @click="window.location.href = redirect;" type="button" class="cursor-pointer whitespace-nowrap rounded-lg bg-red-700 hover:bg-red-800 px-4 py-2 text-center text-sm font-medium tracking-wide text-neutral-100 transition focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-black active:opacity-100 active:outline-offset-0 dark:text-white dark:bg-red-600 dark:hover:bg-red-700 dark:focus-visible:outline-white">I Have Recorded The Code</button>
      </div>
    </div>
  </div>

  {{ if .logoURL }}
  <div class="flex justify-end items-center mt-4">
    <span class="text-xs text-gray-700 dark:text-gray-200 mr-2">Powered by Knot</span>
    <img src="images/logo.svg" alt="Knot logo" class="h-6 opacity-80">
  </div>
  {{ end }}

</div>

{{ end }}
